// ─── Call Flight Recorder ────────────────────────────────────────────────────
// One session = one call attempt on a mobile device.
// Events are stored as a flat JSON array inside the session row for fast
// queries; the indexed columns cover the common admin search paths.

model CallFlightSession {
  id             String    @id @default(cuid())
  // Call identity – at least one of these will be present
  inviteId       String?
  pbxCallId      String?
  linkedId       String?
  // Auth / tenant context
  tenantId       String?
  userId         String?
  deviceId       String?
  extension      String?
  fromNumber     String?
  // Device context
  platform       String    @default("ANDROID")
  appVersion     String?
  networkType    String?
  // Call outcome
  result         String? // answered | missed | declined | failed | ended | unknown
  uiMode         String? // full_screen | floating | in_app
  startedAt      DateTime
  endedAt        DateTime?
  uploadedAt     DateTime  @default(now())
  // Quick-access timing flags (ms)
  answerDelayMs  Int?
  sipConnectMs   Int?
  pushToUiMs     Int?
  // Boolean flags for fast filtering
  hadRingtone    Boolean   @default(false)
  hadBlankScreen Boolean   @default(false)
  hadAppRestart  Boolean   @default(false)
  hadFullScreen  Boolean   @default(false)
  // Automatically detected problems (array of flag strings)
  warningFlags   String[]
  // All timeline events — full structured array stored as JSON
  events         Json      @default("[]")
  // Cached AI diagnosis (generated on demand, stored for reuse)
  aiSummary      Json?

  @@index([inviteId])
  @@index([pbxCallId])
  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, uploadedAt])
  @@index([result])
}

model CallInvite {
  id                 String           @id @default(cuid())
  tenantId           String
  userId             String
  extensionId        String?
  pbxCallId          String?
  pbxSipUsername     String?
  sipCallTarget      String?
  fromDisplay        String?
  createdByEventId   String?
  fromNumber         String
  toExtension        String
  status             CallInviteStatus @default(PENDING)
  createdAt          DateTime         @default(now())
  expiresAt          DateTime
  acceptedAt         DateTime?
  declinedAt         DateTime?
  canceledAt         DateTime?
  heldAt             DateTime?
  resumedAt          DateTime?
  endedAt            DateTime?
  stackOrder         Int?
  acceptedByDeviceId String?
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  extension          Extension?       @relation(fields: [extensionId], references: [id], onDelete: SetNull)
  acceptedByDevice   MobileDevice?    @relation("CallInviteAcceptedByDevice", fields: [acceptedByDeviceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, pbxCallId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, expiresAt])
  @@index([acceptedByDeviceId])
  @@index([userId, status, expiresAt])
  @@index([userId, status, stackOrder])
}

// Push-wake timeline. Every step in the "PBX dialplan -> backend wake -> FCM ->
// device wake -> SIP REGISTER -> INVITE -> answer" pipeline writes a row here so
// we can reconstruct exactly what happened (and where it broke) for any given
// pbxCallId. Cheap append-only log; pruned by the worker after ~14 days.
model CallWakeEvent {
  id          String        @id @default(cuid())
  tenantId    String
  // pbxCallId correlates events across all stages (PBX, backend, device).
  pbxCallId   String
  // userId / deviceId are nullable because the very first event (WAKE_REQUESTED
  // from PBX dialplan) is fired before we resolve which device(s) will be woken.
  userId      String?
  deviceId    String?
  // extensionId is the Connect Extension.id (NOT the PBX extension number)
  extensionId String?
  // Free-form stage label: "WAKE_REQUESTED" | "WAKE_DEVICES_RESOLVED" |
  // "WAKE_PUSH_QUEUED" | "WAKE_PUSH_DELIVERED" | "WAKE_PUSH_FAILED" |
  // "DEVICE_PUSH_RECEIVED" | "DEVICE_REGISTER_TRIGGERED" |
  // "DEVICE_REGISTER_COMPLETE" | "DEVICE_INVITE_RECEIVED" |
  // "DEVICE_ANSWER_TAPPED" | "WAKE_TIMED_OUT".
  stage       String
  // Source of the event row: "pbx_dialplan" | "api" | "device".
  source      String
  // Free-form details (e.g. expoStatus, expoError, registerLatencyMs, etc.).
  // Always JSON-stringifiable. Limited to ~4 KB by convention.
  details     Json?
  // Latency from the FIRST event for this pbxCallId until this event, in ms.
  // Lets the diagnostics UI render a Gantt-style timeline without sorting.
  latencyMs   Int?
  occurredAt  DateTime      @default(now())
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  device      MobileDevice? @relation("CallWakeEventByDevice", fields: [deviceId], references: [id], onDelete: SetNull)
  extension   Extension?    @relation(fields: [extensionId], references: [id], onDelete: SetNull)

  @@index([tenantId, pbxCallId, occurredAt])
  @@index([tenantId, occurredAt])
  @@index([userId, occurredAt])
  @@index([deviceId, occurredAt])
  @@index([stage, occurredAt])
}

// ─── IVR Routing — Option A ─────────────────────────────────────────────────
// Connect manages routing control by owning route profiles, schedules, and
// overrides.  Connect publishes small runtime state to Asterisk AstDB via AMI
// DBPut.  VitalPBX custom contexts read those keys at call time — no HTTP calls
// during live calls, no full PBX mutations per publish.

/// A named routing destination for one mode (business hours, after hours, etc.).
/// pbxDestination is a "context,exten,priority" string, e.g. "app-ivr,8000,1".
model IvrRouteProfile {
  id                     String   @id @default(cuid())
  tenantId               String
  name                   String // human label, e.g. "Main Business IVR"
  type                   String // "business_hours" | "after_hours" | "holiday" | "manual_override" | "emergency"
  pbxDestination         String // "context,exten,priority" written to AstDB (legacy single-dest)
  // Optional greeting/prompt refs for the Connect-owned IVR menu. Values are
  // VitalPBX recording names (e.g. "custom/acme_normal" — no file extension).
  // Empty/null = dialplan plays a safe built-in fallback.
  pbxPromptRef           String? // main greeting
  pbxInvalidPromptRef    String? // played on invalid digit, then re-prompt
  pbxTimeoutPromptRef    String? // played on no-digit timeout, then re-prompt
  pbxRetryPromptRef      String? // VitalPBX-parity "please try again" prompt on retry iterations
  timeoutSeconds         Int      @default(7) // WaitExten timeout per iteration
  maxRetries             Int      @default(3) // retries before falling through to default-fallback
  // VitalPBX-parity IVR controls. All three default to "fall through to the
  // global connect-default-fallback after max retries" so existing profiles
  // behave exactly as they did pre-migration until an admin opts in.
  directDialEnabled      Boolean  @default(false) // allow dial-by-extension during IVR (Read multi-digit)
  invalidDestinationType String? // extension|queue|ring_group|voicemail|ivr|announcement|external_number|terminate|custom
  invalidDestinationRef  String? // CEP or E.164; consumed after max_retries on invalid digits
  timeoutDestinationType String? // same module enum as invalid
  timeoutDestinationRef  String? // CEP or E.164; consumed after max_retries on timeouts
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  createdBy              String? // userId

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleDefault  IvrScheduleConfig[] @relation("ScheduleDefaultProfile")
  scheduleAfterHrs IvrScheduleConfig[] @relation("ScheduleAfterHoursProfile")
  scheduleHoliday  IvrScheduleConfig[] @relation("ScheduleHolidayProfile")
  overrideStates   IvrOverrideState[]
  optionRoutes     IvrOptionRoute[]
  didRouteMappings DidRouteMapping[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
}

/// Per-digit option routing for a tenant's IVR profile.
/// Written to AstDB as `connect/t_<slug>/opt_<digit>/dest` + `.../type` at publish time.
/// optionDigit uses string-safe identifiers: "0".."9", "star" (for *), "hash" (for #).
model IvrOptionRoute {
  id              String   @id @default(cuid())
  tenantId        String
  profileId       String
  optionDigit     String // "0".."9" | "star" | "hash"
  destinationType String // extension|queue|ring_group|voicemail|ivr|announcement|external_number|terminate|custom
  destinationRef  String // "context,exten,priority" | E.164 | etc.
  label           String? // optional human label, e.g. "Sales"
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile IvrRouteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, optionDigit])
  @@index([tenantId])
  @@index([profileId])
}

/// Weekly business hours + holiday rules for a tenant.
/// businessHoursRules JSON: [{ day: 0, open: "09:00", close: "17:00" }, ...]
/// holidayDates JSON:       ["2026-12-25", "2026-01-01", ...]
model IvrScheduleConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  timezone            String   @default("America/New_York")
  businessHoursRules  Json     @default("[]")
  holidayDates        Json     @default("[]")
  defaultProfileId    String? // FK → IvrRouteProfile (business hours)
  afterHoursProfileId String? // FK → IvrRouteProfile (after hours)
  holidayProfileId    String? // FK → IvrRouteProfile (holidays)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultProfile  IvrRouteProfile? @relation("ScheduleDefaultProfile", fields: [defaultProfileId], references: [id], onDelete: SetNull)
  afterHrsProfile IvrRouteProfile? @relation("ScheduleAfterHoursProfile", fields: [afterHoursProfileId], references: [id], onDelete: SetNull)
  holidayProfile  IvrRouteProfile? @relation("ScheduleHolidayProfile", fields: [holidayProfileId], references: [id], onDelete: SetNull)
}

/// Current manual override state for a tenant (one row per tenant).
/// isActive=true means calls are routed to the override profile right now.
model IvrOverrideState {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  isActive      Boolean   @default(false)
  profileId     String? // FK → IvrRouteProfile
  reason        String?
  expiresAt     DateTime? // null = manual until explicitly cleared
  activatedAt   DateTime?
  activatedBy   String? // userId
  deactivatedAt DateTime?
  deactivatedBy String? // userId

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile IvrRouteProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
}

/// Audit log for every AstDB publish (manual or automatic).
/// keysWritten / previousKeys store [{family,key,value}] arrays for rollback.
model IvrPublishRecord {
  id           String   @id @default(cuid())
  tenantId     String
  publishedBy  String // userId or "system"
  publishedAt  DateTime @default(now())
  mode         String // "business" | "afterhours" | "holiday" | "override"
  keysWritten  Json // [{family,key,value}]
  previousKeys Json     @default("[]") // snapshot before publish (for rollback)
  status       String   @default("pending") // "pending" | "success" | "failed"
  error        String?
  isRollback   Boolean  @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, publishedAt])
  @@index([status])
}

// ─── Tenant PBX Prompt Catalog ───────────────────────────────────────────────
// Connect-owned index of VitalPBX System Recordings that belong to each tenant.
// This table is the ONLY source of prompt dropdown data for the IVR UI —
// request-time reads go straight here, never to the PBX.
//
// Population model (all CPU-safe for the PBX):
//   1. Super-admin manual paste (UI / `POST /voice/ivr/prompts/sync`).
//   2. Optional PBX-host cron that POSTs the current `ls sounds/custom` to
//      `/voice/ivr/prompts/sync` on a schedule chosen by ops (typically daily).
//
// Tenant assignment is by filename-prefix convention: a prompt ref like
// `custom/acme_normal` is assigned to the tenant whose `toIvrSlug(name)` slug
// matches the longest leading slug segment of the basename
// (`acme_normal` → slug `acme`). Refs that do not match any tenant slug are
// stored with `tenantId = null` / `tenantSlug = null` and treated as
// "unassigned" (never surfaced in tenant dropdowns, only to super-admins).
//
// No file data is stored here — only pointers. Audio stays in VitalPBX.
model TenantPbxPrompt {
  id           String   @id @default(cuid())
  tenantId     String? // null = unassigned / shared / unknown-ownership
  tenantSlug   String? // denormalised slug used for prefix match (lowercased)
  promptRef    String // canonical dialplan ref, e.g. "custom/acme_normal"
  fileBaseName String // base name without ext, e.g. "acme_normal"
  relativePath String // same as promptRef today; reserved for future non-custom folders
  displayName  String // human-friendly label (defaults to fileBaseName)
  category     String   @default("general") // "greeting" | "invalid" | "timeout" | "general" | "unknown"
  source       String   @default("pbx_sync") // "pbx_sync" | "manual" | "import"
  isActive     Boolean  @default(true)
  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // ── Audio bytes (optional) ────────────────────────────────────────────────
  // Populated by either the PBX-host `connect-prompt-sync.sh` helper (cron
  // pushes new/changed files), or a UI-triggered manual upload. When these
  // are null the catalog row is still valid for dialplan use — only the
  // in-browser "Play" button is unavailable until audio is synced.
  storageKey  String? // relative path under PROMPT_STORAGE_DIR (tenant-scoped, e.g. "tenants/<tenantId>/acme_normal.wav")
  sha256      String? // content hash — used by the PBX helper to diff
  sizeBytes   Int?
  contentType String? // e.g. "audio/wav", "audio/mpeg"
  syncedAt    DateTime? // last time audio bytes were uploaded

  // ── Ownership confidence ──────────────────────────────────────────────────
  // How did we decide this row belongs to `tenantId`?
  //   "exact"   — tenantId resolved from VitalPBX `ombu_recordings.tenant_id`
  //               via TenantPbxLink. This is the authoritative source.
  //   "path"    — folder/path convention (e.g. "custom/<tenant_slug>/foo").
  //   "prefix"  — filename prefix matches a known tenant slug.
  //   "manual"  — an admin set the tenantId via the Connect UI.
  //   "unknown" — we could not determine ownership. Never show in tenant
  //               dropdowns; surface in the super-admin "__unassigned__"
  //               filter only.
  ownershipConfidence String @default("unknown")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Scoped uniqueness: each tenant has its own namespace of promptRefs, so
  // tenant A's `custom/Main` and tenant B's `custom/Main` can co-exist as
  // two separate rows. Null tenantId (unassigned) can appear multiple
  // times under Postgres NULL-uniqueness semantics, which is fine — the
  // super-admin cleanup UI dedupes them.
  @@unique([tenantId, promptRef])
  @@index([tenantId])
  @@index([tenantSlug])
  @@index([tenantId, isActive])
  @@index([isActive])
}

// ─── MOH Scheduling — Option A ───────────────────────────────────────────────
// Connect manages which VitalPBX Music-On-Hold class is active per tenant.
// Connect owns profiles (mappings to existing VitalPBX MOH class names),
// schedules (weekly/holiday/one-time rules), and overrides.
// Connect publishes the effective MOH class name to Asterisk AstDB via AMI DBPut.
// VitalPBX/Asterisk reads `connect/t_{slug}/active_moh_class` at hold/queue time
// via Set(CHANNEL(musicclass)=${DB(...)}) — no streaming from Connect, no HTTP
// during live calls.

/// Maps a human-readable profile name to a pre-existing VitalPBX MOH class.
/// vitalPbxMohClassName must match an existing class in VitalPBX exactly.
/// Unified Hold Profile — controls both the MOH class and optional hold announcement.
/// Renamed conceptually to "Hold Profile" in the UI; table/model name kept for backward compat.
model MohProfile {
  id                          String   @id @default(cuid())
  tenantId                    String
  name                        String // human label, e.g. "Holiday Jazz"
  type                        String // "default" | "business_hours" | "after_hours" | "holiday" | "campaign" | "emergency" | "custom"
  vitalPbxMohClassName        String // exact VitalPBX MOH class name
  holdAnnouncementEnabled     Boolean  @default(false) // whether to play a periodic hold announcement
  holdAnnouncementRef         String? // VitalPBX recording/file ref for the announcement
  holdAnnouncementIntervalSec Int      @default(30) // seconds between announcement playbacks
  introAnnouncementRef        String? // optional one-time intro played on hold entry
  isActive                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  createdBy                   String?
  updatedBy                   String?

  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scheduleDefault    MohScheduleConfig[]    @relation("MohScheduleDefault")
  scheduleAfterHours MohScheduleConfig[]    @relation("MohScheduleAfterHours")
  scheduleHoliday    MohScheduleConfig[]    @relation("MohScheduleHoliday")
  scheduleRules      MohScheduleRule[]
  overrideStates     MohOverrideState[]
  didRouteMappings   DidRouteMapping[]
  extensionOverrides MohExtensionOverride[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
}

/// Per-tenant schedule configuration: timezone and default profile slots.
/// Detailed time rules are in MohScheduleRule (one-to-many).
model MohScheduleConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  timezone            String   @default("America/New_York")
  defaultProfileId    String? // FK → MohProfile (fallback when no rule matches)
  afterHoursProfileId String? // FK → MohProfile (when outside business hours)
  holidayProfileId    String? // FK → MohProfile (on holiday dates)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultProfile  MohProfile?       @relation("MohScheduleDefault", fields: [defaultProfileId], references: [id], onDelete: SetNull)
  afterHrsProfile MohProfile?       @relation("MohScheduleAfterHours", fields: [afterHoursProfileId], references: [id], onDelete: SetNull)
  holidayProfile  MohProfile?       @relation("MohScheduleHoliday", fields: [holidayProfileId], references: [id], onDelete: SetNull)
  rules           MohScheduleRule[]
}

/// Individual time-based rule within a schedule.
/// ruleType: "weekly" | "holiday" | "one_time"
/// For "weekly": weekday (0=Sun…6=Sat), startTime/endTime ("HH:MM")
/// For "holiday": date ("YYYY-MM-DD") stored in startTime, endTime ignored
/// For "one_time": startAt/endAt (UTC timestamps) override everything
model MohScheduleRule {
  id         String    @id @default(cuid())
  scheduleId String
  profileId  String
  ruleType   String // "weekly" | "holiday" | "one_time"
  weekday    Int? // 0=Sun…6=Sat — used for "weekly"
  startTime  String? // "HH:MM" for weekly / "YYYY-MM-DD" for holiday
  endTime    String? // "HH:MM" for weekly
  startAt    DateTime? // UTC — for "one_time" overrides
  endAt      DateTime? // UTC — for "one_time" overrides
  priority   Int       @default(0) // higher = wins on overlap
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  schedule MohScheduleConfig @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  profile  MohProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([scheduleId, isActive])
  @@index([ruleType])
}

/// Current manual override per tenant (upsert: one row per tenant).
/// isActive=true means all schedules are bypassed and profileId is used directly.
model MohOverrideState {
  id            String    @id @default(cuid())
  tenantId      String    @unique
  isActive      Boolean   @default(false)
  profileId     String?
  reason        String?
  expiresAt     DateTime?
  activatedAt   DateTime?
  activatedBy   String?
  deactivatedAt DateTime?
  deactivatedBy String?

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile MohProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
}

/// Audit log for every Hold Profile publish (manual, override, schedule, or rollback).
/// keysWritten stores the full set of AstDB writes (all 6 keys) for this publish.
/// previousKeysSnapshot stores the full AstDB state before this publish — used for rollback.
model MohPublishRecord {
  id                         String   @id @default(cuid())
  tenantId                   String
  publishedBy                String // userId or "system"
  publishedAt                DateTime @default(now())
  source                     String // "schedule" | "manual" | "override" | "rollback" | "reconciliation"
  previousMohClass           String? // display only — class name before this publish
  newMohClass                String // VitalPBX MOH class name written
  keysWritten                Json // [{family,key,value}] — all keys written this publish
  previousKeysSnapshot       Json     @default("[]") // full AstDB key snapshot before this publish (for rollback)
  // Per-extension override snapshot at publish time (Phase 1: column only, populated in a later phase
  // once the publish path writes per-extension keys). Always a JSON array; empty `[]` for legacy rows.
  extensionOverridesSnapshot Json     @default("[]")
  nativeSync                 Json? // PBX helper result for native inbound-route/extension MOH sync
  status                     String   @default("pending") // "pending" | "success" | "failed"
  error                      String?
  isRollback                 Boolean  @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, publishedAt])
  @@index([status])
}

/// Per-extension MOH override (Phase 1 — schema + helpers only; no runtime path yet).
///
/// One row per (tenantId, extension). When `enabled = true`, this row should be
/// the source of truth for the AstDB keys
///   connect/t_<slug>/extensions/<extension>/moh_class
///   connect/t_<slug>/extensions/<extension>/active_moh_class
/// in a future publish phase. Phase 1 does NOT write these keys; the table is
/// inert until the publish helper is wired up.
///
/// `extension` is a normalized string token from CHANNEL(name) (`PJSIP/T<id>_<ext>-...`),
/// not an FK to `Extension` — the canonical channel-name token is what AstDB will
/// key on, and the API layer (Phase 2) is responsible for validating against
/// `Extension` at write time.
model MohExtensionOverride {
  id                   String   @id @default(cuid())
  tenantId             String
  extension            String
  vitalPbxMohClassName String
  mohProfileId         String?
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdBy            String?
  updatedBy            String?

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile MohProfile? @relation(fields: [mohProfileId], references: [id], onDelete: SetNull)

  @@unique([tenantId, extension])
  @@index([tenantId])
  @@index([enabled])
}

/// Bulk MOH assignment job (Phase 1 — schema only; no worker consumer yet).
///
/// Persists requests like "set tenant default for selected tenants" or
/// "set per-extension overrides for selected extensions in one tenant".
/// Deliberately has no FK to Tenant — `targetTenantIds` is opaque so a
/// later cleanup of a deleted tenant does not cascade-delete history.
model MohAssignmentJob {
  id                   String    @id @default(cuid())
  scope                String // "selected_tenants" | "all_tenants" | "selected_extensions"
  targetTenantIds      String[]  @default([])
  targetExtensions     String[]  @default([])
  vitalPbxMohClassName String
  mohProfileId         String?
  mode                 String // "set_tenant_default" | "set_extension_overrides"
  requestedBy          String?
  status               String    @default("pending") // "pending" | "applied" | "failed" | "partial"
  appliedAt            DateTime?
  error                String?
  summary              Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Per-tenant last-known publish state — cached to avoid repeated DB queries from the worker.
/// One row per tenant; upserted on every successful publish.
model MohLastPublishedState {
  tenantId    String   @id
  mohClass    String
  holdMode    String
  publishedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── DID-level routing (shared-entry architecture) ───────────────────────────
// Connect-owned mapping for each inbound phone number: which tenant owns it,
// which IVR profile and MOH/hold profile are active, and which VitalPBX
// inbound-route (if any) was auto-provisioned by Connect via REST.
//
// When admins Publish a DidRouteMapping, Connect:
//   1. (optional, behind PBX_INBOUND_API flag) POSTs /api/v2/tenants/:vt/inbound_numbers
//      on VitalPBX to create/update the inbound route pointing at the shared
//      [connect-tenant-ivr] custom destination with TENANT_SLUG preset.
//   2. Writes AstDB keys via AMI DBPut:
//        connect/didmap/<e164>/tenant        = tenantSlug
//        connect/didmap/<e164>/profile_id    = ivrProfileId or ""
//        connect/didmap/<e164>/moh_class     = resolved MOH class name or ""
//        connect/didmap/<e164>/hold_announce = holdAnnounceRef or ""
//        connect/didmap/<e164>/hold_repeat   = holdRepeatSec or ""
//
// fallbackBehavior controls what the dialplan does if any mapping is missing:
//   "default_ivr"  — fall through to tenant's default business-hours IVR profile
//   "terminate"    — play safe fallback announcement and hang up
//   "voicemail"    — go to the tenant's default voicemail box if configured
model DidRouteMapping {
  id                          String    @id @default(cuid())
  tenantId                    String
  e164                        String // normalised E.164, e.g. "+18005551212"
  phoneNumberId               String? // FK → PhoneNumber (Connect-purchased); null for PBX-owned
  pbxInstanceId               String? // FK → PbxInstance (which PBX holds the inbound route)
  pbxInboundRouteId           String? // VitalPBX inbound route id once auto-created
  ivrProfileId                String? // FK → IvrRouteProfile (active IVR for this DID)
  mohProfileId                String? // FK → MohProfile (active Hold/MOH profile for this DID)
  holdAnnouncePromptRef       String? // VitalPBX recording ref for hold announcement
  holdRepeatSec               Int       @default(30) // seconds between announcement repeats
  fallbackBehavior            String    @default("default_ivr") // "default_ivr" | "terminate" | "voicemail"
  enabled                     Boolean   @default(true)
  lastPublishedAt             DateTime?
  // ── DID takeover (switch between PBX-native routing and Connect IVR) ──
  // `routingMode` tracks where the DID's inbound destination currently points:
  //   "pbx"     → VitalPBX still owns the routing (the factory/legacy destination)
  //   "connect" → Connect has repointed the inbound_number to [connect-tenant-ivr]
  // Before the first "switch to connect" we snapshot the live VitalPBX
  // inbound_number payload into the originalPbx* fields so a later "restore
  // to PBX" can PATCH it back verbatim without operator guesswork.
  routingMode                 String    @default("pbx") // "pbx" | "connect"
  originalPbxDestinationType  String? // e.g. "ivr", "queues", "extensions", "custom-destinations"
  originalPbxDestination      String? // opaque VitalPBX destination string (id or CEP)
  originalPbxChannelVariables Json? // full channel_variables map as last seen on PBX
  originalCapturedAt          DateTime? // when we captured the PBX-native destination
  lastSwitchedAt              DateTime? // last time routingMode flipped
  lastSwitchedBy              String? // user id that performed the flip
  lastSwitchError             String? // surfaced from last failed switch attempt (null on success)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  createdBy                   String?
  updatedBy                   String?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ivrProfile  IvrRouteProfile?    @relation(fields: [ivrProfileId], references: [id], onDelete: SetNull)
  mohProfile  MohProfile?         @relation(fields: [mohProfileId], references: [id], onDelete: SetNull)
  pbxInstance PbxInstance?        @relation(fields: [pbxInstanceId], references: [id], onDelete: SetNull)
  switchLogs  DidRouteSwitchLog[]

  @@unique([e164])
  @@index([tenantId])
  @@index([tenantId, enabled])
  @@index([ivrProfileId])
  @@index([mohProfileId])
  @@index([pbxInstanceId])
  @@index([routingMode])
}

// ─── DID takeover audit log ──────────────────────────────────────────────────
// Every call to /voice/did/:id/switch-to-connect or /switch-to-pbx inserts one
// row so operators can see the full history of who repointed which DID and
// what the PBX state looked like before/after. Cheap to keep (one row per
// toggle) and indispensable for post-mortems when a tenant calls saying
// "my IVR stopped working".
model DidRouteSwitchLog {
  id          String   @id @default(cuid())
  mappingId   String
  tenantId    String
  fromMode    String // "pbx" | "connect"
  toMode      String // "pbx" | "connect"
  performedBy String
  performedAt DateTime @default(now())
  pbxPayload  Json? // what we sent to VitalPBX (null on pure DB updates)
  pbxSnapshot Json? // what we read from VitalPBX before the change
  status      String // "pending" | "success" | "failed"
  error       String? // stringified failure reason when status="failed"

  mapping DidRouteMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@index([mappingId])
  @@index([tenantId, performedAt])
  @@index([status])
}

// ─── MOH uploaded media assets ───────────────────────────────────────────────
// Metadata catalog of tenant-owned music files uploaded to Connect. The actual
// audio bytes live in object storage (S3/R2) at `storageKey`; they are pulled
// by the PBX-host `connect-media-sync` helper on a cron, which drops them into
// /var/lib/asterisk/moh/<mohClassName>/ and runs `asterisk -rx "moh reload"`.
//
// mohClassName is deterministic per tenant+name: "connect_<tenantSlug>_<slug(name)>".
// status flow: uploading -> ready -> (optionally) failed | archived
/// Read-only index of Music-On-Hold classes that already exist on the VitalPBX
/// side (table `ombutel.ombu_music_groups`). Populated by the super-admin
/// "Auto-Sync PBX MOH classes" action which runs the same bounded, indexed
/// MariaDB query pattern as the prompt and DID syncs — no filesystem scan, no
/// call-time traffic, no polling. Admins pick from this catalog when they
/// want a Hold Profile to point at a class VitalPBX already knows about.
///
/// Tenant mapping reuses TenantPbxLink (numeric VitalPBX tenant_id → Connect
/// tenantId). A class whose tenant cannot be resolved is stored with
/// `tenantId = null` so super-admins can still see + re-home it manually.
model PbxMohClass {
  id              String   @id @default(cuid())
  pbxInstanceId   String // which PBX this class lives on
  tenantId        String? // Connect tenant (nullable when mapping unknown)
  tenantSlug      String?
  pbxGroupId      Int // ombu_music_groups.music_group_id
  pbxTenantId     String? // raw VitalPBX numeric tenant_id, as string
  name            String // raw name column (e.g. "default", "main")
  mohClassName    String // name as Asterisk/VitalPBX exposes it — typically equals `name`
  classType       String? // "files" | "stream" | "custom" etc.
  streamingUrl    String?
  streamingFormat String?
  isDefault       Boolean  @default(false)
  fileCount       Int      @default(0) // rolled up from ombu_music_files
  isActive        Boolean  @default(true) // false = removed in VitalPBX on last sync
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pbxInstance PbxInstance @relation(fields: [pbxInstanceId], references: [id], onDelete: Cascade)
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([pbxInstanceId, pbxGroupId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([pbxInstanceId, isActive])
}

model MohAsset {
  id                 String   @id @default(cuid())
  tenantId           String
  tenantSlug         String // denormalised for helper lookups
  name               String // human label, e.g. "Holiday Jazz Mix"
  mohClassName       String // deterministic, e.g. "connect_acme_holiday_jazz"
  sourceFilename     String // original upload filename
  /// Legacy single-key field; new rows mirror PBX artifact key when ready.
  storageKey         String
  originalStorageKey String? // raw upload bytes (preview / history)
  pbxStorageKey      String? // 8 kHz mono 16-bit PCM WAV for Asterisk sync only
  contentHash        String // sha256 hex of PBX artifact when ready (manifest diff)
  sizeBytes          Int // PBX artifact size when ready; otherwise original upload size
  durationSec        Int? // from ffprobe, null until validated
  mimeType           String // legacy; prefer originalMimeType for new rows
  originalMimeType   String?
  pbxFormat          String? // e.g. wav_pcm_s16le_8k_mono
  conversionStatus   String   @default("pending") // pending | ready | failed
  conversionError    String?
  status             String   @default("uploading") // "uploading" | "ready" | "failed" | "archived"
  failureReason      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, mohClassName])
  @@index([contentHash])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status])
}

// ── Connect unified chat (internal + VoIP.ms SMS) ───────────────────────────

enum ConnectChatThreadType {
  SMS
  DM
  GROUP
  TENANT_GROUP
  WHATSAPP
}

enum ConnectChatMessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum ConnectChatMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  VOICE_NOTE
  FILE
  LOCATION
  SYSTEM
}

enum ConnectChatParticipantRole {
  OWNER
  ADMIN
  MEMBER
}

/// Singleton-style row (id = "default") for platform VoIP.ms API credentials.
/// Platform-wide Cardknox/SOLA gateway defaults (iFields public key, etc).
/// Set once; applies to all tenants that have no per-tenant override.
model GlobalSolaConfig {
  id         String   @id @default("default")
  /// Cardknox iFields public key — used by the hosted card-capture form on all tenant billing pages.
  ifieldsKey String?
  updatedAt  DateTime @updatedAt
  updatedBy  String?
}

model GlobalVoipMsConfig {
  id                     String    @id @default("default")
  credentialsEncrypted   String?
  credentialsKeyId       String    @default("v1")
  apiBaseUrl             String?
  smsEnabled             Boolean   @default(false)
  mmsEnabled             Boolean   @default(false)
  webhookSecretEncrypted String?
  lastDidsSyncAt         DateTime?
  lastHealthAt           DateTime?
  lastHealthOk           Boolean?
  lastHealthMessage      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

/// VoIP.ms SMS-capable number assigned to a tenant (optionally to one user/extension).
model TenantSmsNumber {
  id                  String              @id @default(cuid())
  /// Null until assigned to a Connect tenant (synced inventory row).
  tenantId            String?
  provider            IntegrationProvider @default(VOIPMS)
  voipmsDid           String?
  phoneRaw            String?
  phoneE164           String              @unique
  smsCapable          Boolean             @default(true)
  mmsCapable          Boolean             @default(false)
  assignedUserId      String?
  assignedExtensionId String?
  isTenantDefault     Boolean             @default(false)
  active              Boolean             @default(true)
  lastSyncedAt        DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  tenant              Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser        User?               @relation("TenantSmsNumberAssignUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedExtension   Extension?          @relation("TenantSmsNumberAssignExtension", fields: [assignedExtensionId], references: [id], onDelete: SetNull)

  @@index([tenantId, active])
  @@index([tenantId, isTenantDefault])
}

model ConnectChatThread {
  id                   String                   @id @default(cuid())
  tenantId             String
  type                 ConnectChatThreadType
  title                String?
  createdByUserId      String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  lastMessageAt        DateTime                 @default(now())
  isDefaultTenantGroup Boolean                  @default(false)
  active               Boolean                  @default(true)
  /// Stable key: SMS `sms:{tenant}:{tenantE164}:{externalE164}:{inboxScope}` — DM/group unique id
  dedupeKey            String                   @unique
  tenantSmsRaw         String?
  tenantSmsE164        String?
  externalSmsRaw       String?
  externalSmsE164      String?
  /// "" = tenant-wide SMS inbox; else Connect user id for assigned-number personal inbox
  smsInboxOwnerUserId  String                   @default("")
  participants         ConnectChatParticipant[]
  messages             ConnectChatMessage[]
  tenant               Tenant                   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, lastMessageAt])
  @@index([tenantId, type])
  @@index([tenantSmsE164, externalSmsE164])
}

model ConnectChatParticipant {
  id              String                     @id @default(cuid())
  threadId        String
  participantKey  String
  userId          String?
  extensionId     String?
  role            ConnectChatParticipantRole @default(MEMBER)
  joinedAt        DateTime                   @default(now())
  leftAt          DateTime?
  lastReadAt      DateTime?
  typingUntil     DateTime?
  muted           Boolean                    @default(false)
  archivedForUser Boolean                    @default(false)
  thread          ConnectChatThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user            User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  extension       Extension?                 @relation("ConnectChatParticipantExtension", fields: [extensionId], references: [id], onDelete: Cascade)

  @@unique([threadId, participantKey])
  @@index([userId])
}

model ConnectChatMessage {
  id                     String                         @id @default(cuid())
  tenantId               String
  threadId               String
  senderUserId           String?
  senderExtensionId      String?
  direction              ConnectChatMessageDirection
  type                   ConnectChatMessageType         @default(TEXT)
  body                   String                         @default("")
  metadata               Json?
  replyToMessageId       String?
  editedAt               DateTime?
  deletedForEveryoneAt   DateTime?
  deletedForUserIds      Json?
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  smsProviderMessageId   String?
  deliveryStatus         String?
  deliveryError          String?
  externalProvider       String?
  externalMessageId      String?
  externalConversationId String?
  providerStatus         String?
  providerMetadata       Json?
  deliveredAt            DateTime?
  thread                 ConnectChatThread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser             User?                          @relation("ConnectChatMessageSenderUser", fields: [senderUserId], references: [id], onDelete: SetNull)
  replyTo                ConnectChatMessage?            @relation("ConnectChatMessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies                ConnectChatMessage[]           @relation("ConnectChatMessageReply")
  attachments            ConnectChatMessageAttachment[]
  reactions              ConnectChatMessageReaction[]
  whatsAppUsageEvents    WhatsAppUsageEvent[]

  @@index([threadId, createdAt])
  @@index([tenantId, createdAt])
  @@index([smsProviderMessageId])
  @@index([tenantId, externalProvider, externalMessageId])
  @@index([tenantId, externalConversationId])
}

model ConnectChatMessageAttachment {
  id          String             @id @default(cuid())
  messageId   String
  tenantId    String
  fileName    String
  mimeType    String
  sizeBytes   Int
  storageKey  String
  contentHash String?
  scanStatus  String             @default("pending")
  // Cached classifier ("image" | "audio" | "video" | "file") so the chat UI
  // can pick a bubble renderer without re-parsing the MIME on every render.
  mediaKind   String             @default("file")
  // Audio + video duration captured at upload time (ffprobe); null for images
  // and any media we couldn't probe.
  durationMs  Int?
  // Image + video pixel dimensions captured at upload time; null otherwise.
  width       Int?
  height      Int?
  createdAt   DateTime           @default(now())
  message     ConnectChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([messageId])
}

model ConnectChatMessageReaction {
  id        String             @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  message   ConnectChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model SmsRoutingLog {
  id                  String   @id @default(cuid())
  rawFrom             String?
  rawTo               String?
  normalizedFrom      String?
  normalizedTo        String?
  direction           String
  resolvedTenantId    String?
  resolvedUserId      String?
  resolvedExtensionId String?
  resolvedThreadId    String?
  status              String
  error               String?
  payload             Json?
  createdAt           DateTime @default(now())
  tenant              Tenant?  @relation(fields: [resolvedTenantId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([normalizedTo, createdAt])
}

/// Singleton row `id = "default"`. JSON shape: { "END_USER"?: string[], "TENANT_ADMIN"?: string[], "SUPER_ADMIN"?: string[] } (portal permission keys).
model PlatformRolePermissionSnapshot {
  id        String   @id @default("default")
  roles     Json
  updatedAt DateTime @updatedAt
}

// ─── CRM Foundation ───────────────────────────────────────────────────────────

enum CrmUserRole {
  AGENT
  MANAGER
  ADMIN
}

/// Per-tenant CRM feature flags. Created on-demand when a tenant admin enables CRM.
/// Absence of a row = CRM disabled. enabled=false also disables all CRM API routes for the tenant.
model CrmTenantSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  enabled              Boolean  @default(false)
  localPresenceEnabled Boolean  @default(false)
  transcriptionEnabled Boolean  @default(false)
  /// Default sort for the agent queue. One of: SMART | ORIGINAL. Applied when the
  /// agent has no localStorage preference and the URL has no explicit ?sort= param.
  defaultQueueSort     String   @default("SMART")
  /// Default filter tab for the agent queue. One of: PENDING | DUE | OVERDUE | UPCOMING.
  defaultQueueFilter   String   @default("PENDING")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Per-user CRM access grant. Only users with enabled=true can access CRM agent features.
/// Absence of a row = no CRM access for that user (even if CrmTenantSettings.enabled=true).
/// Tenant admins and super admins bypass this check for management routes.
model CrmUserAccess {
  id        String      @id @default(cuid())
  tenantId  String
  userId    String
  enabled   Boolean     @default(true)
  role      CrmUserRole @default(AGENT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, enabled])
}

/// Per-user CRM campaign access. When rows exist for a user, non-admin CRM users
/// only see/work campaigns in this set. Absence of rows = unrestricted (all tenant campaigns).
model CrmUserCampaignAssignment {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  campaignId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, campaignId])
  @@index([tenantId, userId])
  @@index([tenantId, campaignId])
}

// ─── CRM Contacts ─────────────────────────────────────────────────────────────

enum CrmContactStage {
  LEAD
  CONTACTED
  QUALIFIED
  CUSTOMER
  CLOSED_LOST
}

/// CRM metadata overlay on top of an existing Contact record.
/// A Contact becomes a CRM contact when this row is created.
/// Deleting the Contact cascades and removes the CRM meta.
/// No contact data is duplicated — all phones/emails/names live on Contact.
model CrmContactMeta {
  id                String          @id @default(cuid())
  contactId         String          @unique
  tenantId          String
  stage             CrmContactStage @default(LEAD)
  assignedToUserId  String?
  doNotCall         Boolean         @default(false)
  doNotSms          Boolean         @default(false)
  lastActivityAt    DateTime?
  lastDisposition   String?
  lastDispositionAt DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("CrmContactAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, stage])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, createdAt])
  @@index([tenantId, lastActivityAt])
}

// ─── CRM Timeline & Notes ─────────────────────────────────────────────────────

enum CrmCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CrmCampaignPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CrmCampaignMemberStatus {
  PENDING
  IN_PROGRESS
  CONTACTED
  CALLBACK
  CONVERTED
  SKIPPED
  DO_NOT_CALL
}

enum CrmTimelineEventType {
  CONTACT_CREATED
  STAGE_CHANGED
  NOTE_ADDED
  NOTE_EDITED
  TASK_CREATED
  TASK_COMPLETED
  TASK_CANCELED
  CDR_INBOUND
  CDR_OUTBOUND
  CHECKLIST_COMPLETED
  DISPOSITION_SET
  CONTACT_MERGED
  ASSIGNED_TO_USER
  SMS_SENT
  SMS_RECEIVED
  EMAIL_SENT
  EMAIL_RECEIVED
  EMAIL_REPLY
}

/// Immutable audit-style record of CRM activity for a contact.
/// body stores human-readable content (note text, stage description).
/// metadata stores machine-readable detail (e.g. { from, to } for stage changes).
/// linkedId references an external row (e.g. CrmContactNote.id, ConnectCdr.id).
/// Do NOT delete timeline events; they are an append-only log.
model CrmTimelineEvent {
  id              String               @id @default(cuid())
  tenantId        String
  contactId       String
  type            CrmTimelineEventType
  title           String
  body            String?
  metadata        Json?
  linkedId        String?
  createdByUserId String?
  createdAt       DateTime             @default(now())

  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("CrmTimelineEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, contactId, createdAt])
  @@index([tenantId, type, createdAt])
  @@index([contactId, createdAt])
  @@index([contactId, linkedId]) // fast dedup lookup for CDR hook
}

/// Structured notes on a CRM contact. Multiple notes per contact; each has an author.
/// When a note is created, a CrmTimelineEvent(NOTE_ADDED) is also written.
/// When edited, both the note body and the linked timeline event body are updated.
model CrmContactNote {
  id              String   @id @default(cuid())
  tenantId        String
  contactId       String
  body            String
  pinned          Boolean  @default(false)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdByUser User    @relation("CrmContactNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, contactId, createdAt])
  @@index([contactId, createdAt])
}

// ─── CRM Tasks ────────────────────────────────────────────────────────────────

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

/// A follow-up task or action item linked to a CRM contact.
/// Timeline events are written for creation, completion, and cancellation.
/// Minor edits (title, body, dueAt, priority) do NOT write timeline events.
model CrmContactTask {
  id                String          @id @default(cuid())
  tenantId          String
  contactId         String
  title             String
  body              String?
  dueAt             DateTime?
  assignedToUserId  String?
  priority          CrmTaskPriority @default(MEDIUM)
  status            CrmTaskStatus   @default(OPEN)
  completedAt       DateTime?
  completedByUserId String?
  createdByUserId   String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo  User?   @relation("CrmTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  completedBy User?   @relation("CrmTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  createdBy   User    @relation("CrmTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, contactId, status, dueAt])
  @@index([tenantId, assignedToUserId, status, dueAt])
  @@index([tenantId, status, dueAt])
}

// ─── CRM Import ───────────────────────────────────────────────────────────────

enum CrmImportBatchStatus {
  PENDING
  PROCESSING
  DONE
  PARTIAL
  FAILED
}

/// Tracks a single CSV import run. Rows are processed synchronously for MVP.
/// errors Json stores per-row error details: [{ row: number, reason: string }]
/// mapping Json stores the auto-detected column mapping: { csvHeader: fieldKey }
model CrmImportBatch {
  id              String               @id @default(cuid())
  tenantId        String
  fileName        String
  status          CrmImportBatchStatus @default(PENDING)
  totalRows       Int                  @default(0)
  processedRows   Int                  @default(0)
  createdCount    Int                  @default(0)
  updatedCount    Int                  @default(0)
  skippedCount    Int                  @default(0)
  errorCount      Int                  @default(0)
  errors          Json                 @default("[]")
  mapping         Json?
  createdByUserId String
  createdAt       DateTime             @default(now())
  completedAt     DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
}

/// Call script — plain-text body shown in the Live Call Workspace.
/// Agents select a script before or during a call. Not linked to a contact directly.
model CrmScript {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  body            String   @db.Text
  isActive        Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User          @relation("CrmScriptCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  campaigns CrmCampaign[]

  @@index([tenantId, isActive, createdAt])
}

/// Call checklist template — a named list of required/optional items.
/// Agents fill in a CrmChecklistResponse per call/contact.
model CrmChecklist {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  isActive        Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                   @relation("CrmChecklistCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     CrmChecklistItem[]
  responses CrmChecklistResponse[]
  campaigns CrmCampaign[]

  @@index([tenantId, isActive, createdAt])
}

/// Individual item inside a CrmChecklist template.
model CrmChecklistItem {
  id          String  @id @default(cuid())
  checklistId String
  label       String
  required    Boolean @default(false)
  sortOrder   Int     @default(0)

  checklist CrmChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId, sortOrder])
}

/// A saved agent response to a checklist during a call.
/// answers is a JSON map of { [itemId]: boolean }.
/// CHECKLIST_COMPLETED timeline event is written when this is created.
model CrmChecklistResponse {
  id                String   @id @default(cuid())
  tenantId          String
  checklistId       String
  contactId         String
  linkedId          String? // CDR linkedId if call is known; null if saved offline
  completedByUserId String
  answers           Json // { [itemId]: boolean }
  createdAt         DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklist   CrmChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  completedBy User         @relation("CrmChecklistResponseCompletedBy", fields: [completedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, contactId, createdAt])
  @@index([contactId, createdAt])
}

// ─── CRM Campaigns ────────────────────────────────────────────────────────────

/// A named outbound calling campaign. Members are contacts enrolled in the campaign.
/// Optionally linked to a CrmScript and/or CrmChecklist for agent use.
model CrmCampaign {
  id              String              @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  status          CrmCampaignStatus   @default(DRAFT)
  priority        CrmCampaignPriority @default(NORMAL)
  scriptId        String?
  checklistId     String?
  createdByUserId String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User                        @relation("CrmCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  script     CrmScript?                  @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  checklist  CrmChecklist?               @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  members    CrmCampaignMember[]
  userAccess CrmUserCampaignAssignment[]

  @@index([tenantId, status, createdAt])
}

/// A single contact enrolled in a CrmCampaign — the primary queue row.
/// One contact can appear in multiple campaigns, but only once per campaign (@@unique).
/// attemptCount tracks how many call outcomes have been saved for this member.
model CrmCampaignMember {
  id               String                  @id @default(cuid())
  tenantId         String
  campaignId       String
  contactId        String
  assignedToUserId String?
  status           CrmCampaignMemberStatus @default(PENDING)
  attemptCount     Int                     @default(0)
  lastAttemptAt    DateTime?
  sortOrder        Int                     @default(0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign   CrmCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo User?       @relation("CrmCampaignMemberAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  callbackAt   DateTime?
  callbackNote String?

  @@unique([campaignId, contactId])
  @@index([tenantId, campaignId, status, sortOrder])
  @@index([tenantId, assignedToUserId, status])
  @@index([tenantId, assignedToUserId, status, callbackAt])
}

// Add back-relations to CrmScript and CrmChecklist so campaigns can link to them
// (required by Prisma for optional FK relations pointing back)
// These are added inline here to avoid schema-order dependency issues.

/// Phase 4B — CRM Local Presence Caller ID Pool.
/// Associates tenant-owned PhoneNumber DIDs with 3-digit US area codes so that
/// selectCrmCallerId() can pick the best outbound caller ID for a destination.
/// Only PhoneNumber rows belonging to the same tenant may be added.
/// The actual call is still placed client-side via SIP/WebRTC; this is advisory only.
model CrmCallerIdPool {
  id            String   @id @default(cuid())
  tenantId      String
  phoneNumberId String
  areaCode3     String   @db.VarChar(3) /// 3-digit US area code, e.g. "512"
  label         String? /// Optional human label for the pool entry
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant      @relation("TenantCrmCallerIdPool", fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber @relation("PhoneNumberCrmCallerIdPool", fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId, areaCode3, isActive])
  @@index([tenantId, isActive])
}

/// Tenant-scoped custom role. Permissions are additive on top of the built-in role bucket.
/// permissions is a JSON array of PortalPermissionKey strings.
model CustomRole {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  active          Boolean  @default(true)
  permissions     Json     @default("[]")
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("CustomRoleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy       User?            @relation("CustomRoleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  userAssignments UserCustomRole[]

  @@unique([tenantId, name])
  @@index([tenantId, active])
}

/// Assignment of a CustomRole to a User within a tenant.
model UserCustomRole {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  customRoleId     String
  assignedByUserId String?
  createdAt        DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  assignedBy User?      @relation("UserCustomRoleAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, customRoleId])
  @@index([tenantId, userId])
  @@index([tenantId, customRoleId])
}

enum OnboardingStatus {
  INVITE_SENT
  IN_PROGRESS
  SUBMITTED
  AWAITING_PBX_SETUP
  AWAITING_PORT
  AWAITING_PAYMENT
  READY_TO_SYNC
  ACTIVE
  COMPLETED
  CANCELED
}

enum OnboardingEventType {
  CREATED
  AUTOSAVED
  FILE_UPLOADED
  STATUS_CHANGED
  CHECKLIST_UPDATED
  NOTES_UPDATED
  SUBMITTED
}

model OnboardingSubmission {
  id                    String                     @id @default(cuid())
  publicToken           String?                    @unique
  companyName           String?
  contactFirstName      String?
  contactLastName       String?
  mainEmail             String?
  billingEmail          String?
  mainPhone             String?
  phoneNumberChoice     String?
  smsEnabled            Boolean                    @default(false)
  smsMonthlyPriceCents  Int                        @default(0)
  status                OnboardingStatus           @default(INVITE_SENT)
  currentStep           String?
  answers               Json?
  provisioningChecklist Json?
  internalNotes         Json?
  cardTokenPreview      String?
  createdTenantId       String?
  submittedAt           DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  requestedExtensions   OnboardingRequestedExtension[]
  uploadedFiles         OnboardingUploadedFile[]
  events                OnboardingEvent[]
}

model OnboardingRequestedExtension {
  id           String               @id @default(cuid())
  submissionId String
  displayName  String?
  extNumber    String
  email        String?
  smsEnabled   Boolean              @default(false)
  createdAt    DateTime             @default(now())

  submission   OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model OnboardingUploadedFile {
  id           String               @id @default(cuid())
  submissionId String
  filename     String
  mimeType     String?
  sizeBytes    Int
  storageKey   String
  kind         String
  createdAt    DateTime             @default(now())

  submission   OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model OnboardingEvent {
  id           String               @id @default(cuid())
  submissionId String
  type         OnboardingEventType
  message      String?
  createdAt    DateTime             @default(now())

  submission   OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

// ─── CRM Funders ─────────────────────────────────────────────────────────────
// Separate entity workspace for funding/referral/insurance/provider records.
// Deliberately NOT reusing Contact to avoid cross-contamination of CRM contact
// workflows, tags, and CDR screen-pop. Funders have their own tag namespace.

enum FunderStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  PENDING
}

model Funder {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  organization String?
  email        String?
  phone        String?
  phone2       String?
  city         String?
  state        String?
  zip          String?
  notes        String?
  status       FunderStatus @default(ACTIVE)
  active       Boolean      @default(true)
  archivedAt   DateTime?
  createdBy    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator  User?                  @relation("FunderCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  tagLinks FunderTagAssignment[]

  @@index([tenantId, active])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, name])
}

model FunderTag {
  id          String               @id @default(cuid())
  tenantId    String
  name        String
  color       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments FunderTagAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model FunderTagAssignment {
  funderId String
  tagId    String
  funder   Funder    @relation(fields: [funderId], references: [id], onDelete: Cascade)
  tag      FunderTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([funderId, tagId])
  @@index([tagId])
}

model FunderImportBatch {
  id           String   @id @default(cuid())
  tenantId     String
  fileName     String
  status       String   @default("PENDING")
  totalRows    Int      @default(0)
  createdCount Int      @default(0)
  updatedCount Int      @default(0)
  skippedCount Int      @default(0)
  errorCount   Int      @default(0)
  errors       Json     @default("[]")
  mapping      Json     @default("{}")
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}
