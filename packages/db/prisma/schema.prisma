generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenDlcStatus {
  DRAFT
  SUBMITTED
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  PAUSED
  NEEDS_APPROVAL
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
}

enum IntegrationProvider {
  TWILIO
  VOIPMS
}

enum SmsSendMode {
  TEST
  LIVE
}

enum SmsProviderRoutingMode {
  SINGLE_PRIMARY
  FAILOVER
}

enum PhoneNumberProvider {
  TWILIO
  VOIPMS
}

enum WhatsAppProviderType {
  WHATSAPP_TWILIO
  WHATSAPP_META
}

enum EmailProviderType {
  SENDGRID
  SMTP
  GOOGLE_WORKSPACE
}

enum InvoiceStatus {
  DRAFT
  SENT
  OVERDUE
  PAID
  VOID
}

enum EmailJobStatus {
  QUEUED
  RUNNING
  SENT
  FAILED
}

enum PhoneNumberStatus {
  ACTIVE
  RELEASING
  RELEASED
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  PENDING
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SolaConfigMode {
  SANDBOX
  PROD
}

enum SolaAuthMode {
  XKEY_BODY
  AUTHORIZATION_HEADER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum PbxLinkStatus {
  LINKED
  UNLINKED
  ERROR
}

enum PbxRouteType {
  MAIN_IVR
  RING_GROUP
  QUEUE
  EXTENSION
  CUSTOM
}

enum PbxJobStatus {
  QUEUED
  RUNNING
  FAILED
  COMPLETED
}

enum DtmfMode {
  RFC2833
  SIP_INFO
}

enum MobilePlatform {
  IOS
  ANDROID
}

enum TurnValidationStatus {
  UNKNOWN
  VERIFIED
  FAILED
  STALE
}

enum TurnConfigScope {
  GLOBAL
  TENANT
}

enum TurnValidationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum VoiceClientPlatform {
  WEB
  IOS
  ANDROID
}

enum VoiceDiagRegState {
  IDLE
  REGISTERING
  REGISTERED
  FAILED
}

enum VoiceDiagCallState {
  IDLE
  DIALING
  RINGING
  CONNECTED
  ENDED
}

enum VoiceDiagEventType {
  SESSION_START
  SESSION_HEARTBEAT
  SIP_REGISTER
  SIP_UNREGISTER
  WS_CONNECTED
  WS_DISCONNECTED
  WS_RECONNECT
  ICE_GATHERING
  ICE_SELECTED_PAIR
  TURN_TEST_RESULT
  INCOMING_INVITE
  ANSWER_TAPPED
  CALL_CONNECTED
  CALL_ENDED
  ERROR
  MEDIA_TEST_RUN
}

enum MediaTestStatus {
  UNKNOWN
  PASSED
  FAILED
  STALE
}

enum MediaTestRunStatus {
  QUEUED
  PASSED
  FAILED
}

enum MediaPolicy {
  TURN_ONLY
  RTPENGINE_PREFERRED
}

enum SbcMode {
  LOCAL
  REMOTE
}

enum CallInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

model Tenant {
  id                            String                 @id @default(cuid())
  name                          String
  isApproved                    Boolean                @default(false)
  dailySmsCap                   Int                    @default(100)
  perSecondRate                 Float                  @default(1.0)
  firstCampaignRequiresApproval Boolean                @default(true)
  smsSendMode                   SmsSendMode            @default(TEST)
  smsLiveEnabledAt              DateTime?
  smsLiveEnabledByUserId        String?
  dailySmsLimit                 Int                    @default(500)
  hourlySmsLimit                Int                    @default(100)
  perSecondRateLimit            Int                    @default(5)
  maxCampaignSize               Int                    @default(2000)
  smsSuspended                  Boolean                @default(false)
  smsSuspendedReason            String?
  smsSuspendedAt                DateTime?
  smsRoutingMode                SmsProviderRoutingMode @default(FAILOVER)
  smsPrimaryProvider            IntegrationProvider    @default(TWILIO)
  smsSecondaryProvider          IntegrationProvider?   @default(VOIPMS)
  smsProviderLock               IntegrationProvider?
  smsProviderLockReason         String?
  smsProviderLockedAt           DateTime?
  smsProviderLockedByUserId     String?
  defaultSmsFromNumberId        String?
  defaultVoiceFromNumberId      String?
  numberPurchaseEnabled         Boolean                @default(true)
  smsSubscriptionRequired       Boolean                @default(true)
  smsBillingEnforced            Boolean                @default(true)
  webrtcEnabled                 Boolean                @default(false)
  webrtcRouteViaSbc             Boolean                @default(false)
  sipWsUrl                      String?
  sipDomain                     String?
  iceServers                    Json?
  outboundProxy                 String?
  dtmfMode                      DtmfMode               @default(RFC2833)
  turnRequiredForMobile         Boolean                @default(false)
  turnValidationStatus          TurnValidationStatus   @default(UNKNOWN)
  turnValidatedAt               DateTime?
  turnLastErrorCode             String?
  turnLastErrorAt               DateTime?
  mediaReliabilityGateEnabled   Boolean                @default(false)
  mediaTestStatus               MediaTestStatus        @default(UNKNOWN)
  mediaTestedAt                 DateTime?
  mediaLastErrorCode            String?
  mediaLastErrorAt              DateTime?
  mediaPolicy                  MediaPolicy            @default(TURN_ONLY)
  sbcUdpExposureConfirmed      Boolean                @default(false)
  sbcUdpExposureConfirmedAt    DateTime?
  sbcUdpExposureConfirmedByUserId String?
  createdAt                     DateTime               @default(now())
  users                         User[]
  tenDlcSubs                    TenDlcSubmission[]
  campaigns                     SmsCampaign[]
  numbers                       PhoneNumber[]          @relation("TenantOwnedNumbers")
  audits                        AuditLog[]
  providerCredentials           ProviderCredential[]
  billingSolaConfig             BillingSolaConfig?
  whatsappProviderConfigs       WhatsAppProviderConfig[]
  whatsAppThreads               WhatsAppThread[]
  whatsAppMessages              WhatsAppMessage[]
  emailProviderConfig           EmailProviderConfig?
  webhookEvents                 SmsWebhookEvent[]
  providerHealth                ProviderHealth[]
  subscription                  Subscription?
  paymentEvents                 PaymentEvent[]
  usageLedger                   UsageLedger[]
  receipts                      Receipt[]
  invoices                      Invoice[]
  customers                     Customer[]
  customerNotes                 CustomerNote[]
  customerTasks                 CustomerTask[]
  automationRules               AutomationRule[]
  invoiceEvents                 InvoiceEvent[]
  emailJobs                     EmailJob[]
  alerts                        Alert[]
  extensions                    Extension[]
  callRecords                   CallRecord[]
  mobileDevices                 MobileDevice[]
  callInvites                   CallInvite[]
  voiceClientSessions           VoiceClientSession[]
  voiceDiagEvents               VoiceDiagEvent[]
  mediaTestRuns                 MediaTestRun[]
  turnConfigs                   TurnConfig[]
  turnValidationJobs            TurnValidationJob[]
  mobileProvisioningTokens      MobileProvisioningToken[]
  pbxTenantLink                 TenantPbxLink?
  pbxExtensionLinks             PbxExtensionLink[]
  pbxDidLinks                   PbxDidLink[]
  pbxCdrCursor                  PbxCdrCursor?
  pbxJobs                       PbxJob[]
  ivrSchedules                  IvrSchedule[]
  pbxCallEvents                 PbxCallEvent[]
  smsLiveEnabledByUser          User?                  @relation("TenantSmsLiveEnabledBy", fields: [smsLiveEnabledByUserId], references: [id], onDelete: SetNull)
  smsProviderLockedByUser       User?                  @relation("TenantSmsProviderLockedBy", fields: [smsProviderLockedByUserId], references: [id], onDelete: SetNull)
  defaultSmsFromNumber          PhoneNumber?           @relation("TenantDefaultSmsFromNumber", fields: [defaultSmsFromNumberId], references: [id], onDelete: SetNull)
}

model User {
  id                         String               @id @default(cuid())
  tenantId                   String
  email                      String               @unique
  passwordHash               String
  role                       UserRole             @default(USER)
  createdAt                  DateTime             @default(now())
  tenant                     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents                AuditLog[]           @relation("AuditActor")
  createdProviderCredentials ProviderCredential[] @relation("ProviderCredentialCreatedBy")
  updatedProviderCredentials ProviderCredential[] @relation("ProviderCredentialUpdatedBy")
  createdBillingSolaConfigs BillingSolaConfig[]  @relation("BillingSolaConfigCreatedBy")
  updatedBillingSolaConfigs BillingSolaConfig[]  @relation("BillingSolaConfigUpdatedBy")
  createdWhatsAppProviderConfigs WhatsAppProviderConfig[] @relation("WhatsAppProviderConfigCreatedBy")
  updatedWhatsAppProviderConfigs WhatsAppProviderConfig[] @relation("WhatsAppProviderConfigUpdatedBy")
  createdEmailProviderConfigs    EmailProviderConfig[]    @relation("EmailProviderConfigCreatedBy")
  updatedEmailProviderConfigs    EmailProviderConfig[]    @relation("EmailProviderConfigUpdatedBy")
  smsLiveEnabledTenants      Tenant[]             @relation("TenantSmsLiveEnabledBy")
  smsProviderLockedTenants   Tenant[]             @relation("TenantSmsProviderLockedBy")
  ownedExtensions            Extension[]          @relation("ExtensionOwner")
  mobileDevices              MobileDevice[]
  callInvites                CallInvite[]
  voiceClientSessions        VoiceClientSession[]
  voiceDiagEvents            VoiceDiagEvent[]
  requestedTurnValidationJobs TurnValidationJob[] @relation("TurnValidationRequestedBy")
  requestedMediaTestRuns     MediaTestRun[]      @relation("MediaTestRequestedBy")
  mobileProvisioningTokens    MobileProvisioningToken[]
  updatedSbcConfigs           SbcConfig[]        @relation("SbcConfigUpdatedBy")
  customerNotes               CustomerNote[]
  createdCustomerTasks        CustomerTask[]     @relation("CustomerTaskCreatedBy")
  completedCustomerTasks      CustomerTask[]     @relation("CustomerTaskCompletedBy")
  createdAutomationRules      AutomationRule[]   @relation("AutomationRuleCreatedBy")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BILLING
  MESSAGING
  SUPPORT
  READ_ONLY
  USER
}

enum CustomerStatus {
  ACTIVE
  PAST_DUE
  INACTIVE
}

enum CustomerTaskStatus {
  OPEN
  DONE
}

enum CustomerTaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Subscription {
  id                      String             @id @default(cuid())
  tenantId                String             @unique
  planCode                String
  priceCents              Int
  currency                String             @default("USD")
  status                  SubscriptionStatus @default(NONE)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  provider                String             @default("SOLA_CARDKNOX")
  providerCustomerId      String?
  providerSubscriptionId  String?
  providerPaymentMethodId String?
  billingEmail            String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  paymentMethodExpMonth   String?
  paymentMethodExpYear    String?
  lastPaymentStatus       PaymentStatus?
  lastPaymentAt           DateTime?
  lastFailureReason       String?
  pastDueSince            DateTime?
  retryCount              Int                @default(0)
  nextRetryAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentEvents           PaymentEvent[]
  receipts                Receipt[]
}

model PaymentEvent {
  id              String        @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  provider        String
  providerEventId String?
  type            String
  status          PaymentStatus
  amountCents     Int?
  currency        String?
  payload         Json
  receivedAt      DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([tenantId, receivedAt])
}

model UsageLedger {
  id             String   @id @default(cuid())
  tenantId       String
  type           String
  quantity       Int      @default(1)
  unitPriceCents Int
  totalCents     Int
  referenceId    String?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
}

model TenDlcSubmission {
  id                    String       @id @default(cuid())
  tenantId              String
  legalName             String
  dba                   String?
  einEncrypted          String
  businessType          String
  websiteUrl            String
  addressStreet         String
  addressCity           String
  addressState          String
  addressPostalCode     String
  addressCountry        String
  supportEmail          String
  supportPhone          String
  useCaseCategory       String
  sampleMessage1        String
  sampleMessage2        String
  sampleMessage3        String
  optInMethod           String
  optInWorkflow         String
  optInProofUrl         String?
  messagesPerDay        Int
  messagesPerMonth      Int
  includesEmbeddedLinks Boolean
  includesPhoneNumbers  Boolean
  includesAffiliateMktg Boolean
  ageGatedContent       Boolean
  termsAccepted         Boolean
  signatureName         String
  signatureDate         DateTime
  status                TenDlcStatus @default(SUBMITTED)
  internalNotes         String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime     @default(now())
  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsCampaign {
  id               String         @id @default(cuid())
  tenantId         String
  name             String
  message          String
  fromNumber       String
  audienceType     String
  requiresApproval Boolean        @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  holdReason       String?
  riskScore        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages         SmsMessage[]
}

model SmsMessage {
  id                   String               @id @default(cuid())
  campaignId           String
  toNumber             String
  fromNumber           String
  fromNumberId         String?
  body                 String
  status               SmsMessageStatus     @default(QUEUED)
  providerMessageId    String?
  providerStatus       String?
  provider             IntegrationProvider?
  providerErrorCode    String?
  providerAttemptedAt  DateTime?
  providerRoute        String?
  lastProviderUpdateAt DateTime?
  deliveryUpdatedAt    DateTime?
  error                String?
  createdAt            DateTime             @default(now())
  sentAt               DateTime?
  campaign             SmsCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromNumberRef        PhoneNumber?         @relation("SmsMessageFromNumber", fields: [fromNumberId], references: [id], onDelete: SetNull)
  webhookEvents        SmsWebhookEvent[]
}

model SmsWebhookEvent {
  id                String              @id @default(cuid())
  tenantId          String?
  provider          IntegrationProvider
  messageId         String?
  providerMessageId String
  eventType         String
  payload           Json
  receivedAt        DateTime            @default(now())
  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  message           SmsMessage?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([provider, providerMessageId])
  @@index([tenantId, receivedAt])
}

model ProviderHealth {
  id               String              @id @default(cuid())
  tenantId         String
  provider         IntegrationProvider
  windowStart      DateTime
  sentCount        Int                 @default(0)
  failCount        Int                 @default(0)
  lastErrorCode    String?
  lastErrorAt      DateTime?
  circuitOpenUntil DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, windowStart])
  @@index([tenantId, provider])
}

model PhoneNumber {
  id                String              @id @default(cuid())
  tenantId          String
  provider          PhoneNumberProvider
  phoneNumber       String              @unique
  providerId        String?
  friendlyName      String?
  capabilities      Json?
  region            String?
  areaCode          String?
  monthlyCostCents  Int?
  status            PhoneNumberStatus   @default(ACTIVE)
  purchasedAt       DateTime            @default(now())
  releasedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenant            Tenant              @relation("TenantOwnedNumbers", fields: [tenantId], references: [id], onDelete: Cascade)
  defaultForTenants Tenant[]            @relation("TenantDefaultSmsFromNumber")
  smsMessages       SmsMessage[]        @relation("SmsMessageFromNumber")
  pbxDidLinks       PbxDidLink[]

  @@index([tenantId, status])
  @@index([provider, status])
}

model ProviderCredential {
  id                   String              @id @default(cuid())
  tenantId             String
  provider             IntegrationProvider
  label                String?
  isEnabled            Boolean             @default(false)
  credentialsEncrypted String
  credentialsKeyId     String              @default("v1")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User                @relation("ProviderCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User                @relation("ProviderCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, provider])
}

model BillingSolaConfig {
  id                   String         @id @default(cuid())
  tenantId             String         @unique
  isEnabled            Boolean        @default(false)
  apiBaseUrl           String
  mode                 SolaConfigMode @default(SANDBOX)
  simulate             Boolean        @default(false)
  authMode             SolaAuthMode   @default(XKEY_BODY)
  authHeaderName       String?
  pathOverrides        Json?
  credentialsEncrypted String
  credentialsKeyId     String         @default("v1")
  lastTestAt           DateTime?
  lastTestResult       String?
  lastTestErrorCode    String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User           @relation("BillingSolaConfigCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User           @relation("BillingSolaConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@index([isEnabled, updatedAt])
}

model WhatsAppProviderConfig {
  id                   String               @id @default(cuid())
  tenantId             String
  provider             WhatsAppProviderType
  isEnabled            Boolean              @default(false)
  settings             Json?
  credentialsEncrypted String
  credentialsKeyId     String               @default("v1")
  lastTestAt           DateTime?
  lastTestResult       String?
  lastTestErrorCode    String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User                 @relation("WhatsAppProviderConfigCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User                 @relation("WhatsAppProviderConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, provider])
  @@index([tenantId, isEnabled])
}

model WhatsAppThread {
  id                 String               @id @default(cuid())
  tenantId           String
  customerId         String?
  providerType       WhatsAppProviderType
  contactNumber      String
  contactName        String?
  lastMessageAt      DateTime             @default(now())
  lastMessagePreview String?
  lastDirection      String?
  lastStatus         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages           WhatsAppMessage[]

  @@unique([tenantId, providerType, contactNumber])
  @@index([tenantId, updatedAt])
  @@index([tenantId, customerId])
}

model WhatsAppMessage {
  id                String               @id @default(cuid())
  tenantId          String
  threadId          String
  providerType      WhatsAppProviderType
  direction         String
  fromNumber        String
  toNumber          String
  body              String
  externalMessageId String?
  status            String
  errorCode         String?
  metadata          Json?
  deliveredAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread            WhatsAppThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([threadId, createdAt])
  @@index([externalMessageId])
}

model EmailProviderConfig {
  id                   String            @id @default(cuid())
  tenantId             String            @unique
  provider             EmailProviderType
  fromName             String?
  fromEmail            String?
  replyTo              String?
  logoUrl              String?
  footerText           String?
  settings             Json?
  credentialsEncrypted String
  credentialsKeyId     String            @default("v1")
  isEnabled            Boolean           @default(false)
  lastTestAt           DateTime?
  lastTestResult       String?
  lastTestErrorCode    String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User              @relation("EmailProviderConfigCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User              @relation("EmailProviderConfigUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)
}

model Invoice {
  id                   String       @id @default(cuid())
  tenantId             String
  customerId           String?
  customerEmail        String
  customerPhone        String?
  amountCents          Int
  currency             String       @default("USD")
  status               InvoiceStatus @default(DRAFT)
  dueAt                DateTime?
  paidAt               DateTime?
  externalPaymentLink  String?
  payToken             String?      @unique
  payTokenExpiresAt    DateTime?
  providerInvoiceRef   String?
  lastFailureReason    String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer             Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  events               InvoiceEvent[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
}

model Customer {
  id             String          @id @default(cuid())
  tenantId       String
  displayName    String
  companyName    String?
  primaryEmail   String?
  primaryPhone   String?
  whatsappNumber String?
  notes          String?
  tags           Json?
  status         CustomerStatus  @default(ACTIVE)
  lastContactAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  whatsAppThreads WhatsAppThread[]
  customerNotes  CustomerNote[]
  customerTasks  CustomerTask[]
  pbxCallEvents  PbxCallEvent[]

  @@index([tenantId, displayName])
  @@index([tenantId, primaryEmail])
  @@index([tenantId, primaryPhone])
  @@index([tenantId, whatsappNumber])
  @@index([tenantId, status])
  @@index([tenantId, lastContactAt])
}

model CustomerTask {
  id                 String               @id @default(cuid())
  tenantId           String
  customerId         String
  title              String
  body               String?
  status             CustomerTaskStatus   @default(OPEN)
  priority           CustomerTaskPriority @default(MEDIUM)
  dueAt              DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  completedAt        DateTime?
  createdByUserId    String
  completedByUserId  String?
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer           Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdByUser      User                 @relation("CustomerTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  completedByUser    User?                @relation("CustomerTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, updatedAt])
  @@index([customerId, createdAt])
}

model AutomationRule {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  triggerType     String
  actionType      String
  actionPayload   Json?
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser   User     @relation("AutomationRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, triggerType])
}

model IvrSchedule {
  id          String   @id @default(cuid())
  tenantId    String
  ivrId       String
  recordingId String
  startTime   DateTime
  endTime     DateTime
  timezone    String   @default("UTC")
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

