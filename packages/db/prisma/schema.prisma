// Connect-owned CDR — one row per completed canonical call.
// Populated by the telephony service via /internal/cdr-ingest when a call ends.
// This is the authoritative source for dashboard KPI cards and call history.
model ConnectCdr {
  id                     String    @id @default(cuid())
  linkedId               String    @unique // Asterisk Linkedid — canonical dedupe key
  tenantId               String? // Connect Tenant.id when linked; else vpbx:{slug}; null = unassigned
  pbxVitalTenantId       String? // VitalPBX tenant_id (numeric string, e.g. "8")
  pbxTenantCode          String? // Canonical label e.g. "T8"
  tenantResolutionSource String? // audit: how tenantId was chosen
  fromNumber             String?
  fromName               String? // CNAM from AMI CallerIDName (caller's display name)
  toNumber               String?
  direction              String // "incoming" | "outgoing" | "internal" | "unknown"
  disposition            String // "answered" | "missed" | "busy" | "failed" | "canceled" | "unknown"
  startedAt              DateTime
  answeredAt             DateTime?
  endedAt                DateTime
  durationSec            Int       @default(0) // wall time: endedAt - startedAt (seconds)
  talkSec                Int       @default(0) // talk time: endedAt - answeredAt (0 if unanswered)
  queueId                String?
  hangupCause            String?
  dcontext               String? // AMI Cdr dcontext — most authoritative direction signal (e.g. "ext-local-gesheft")
  dcontextsSeen          Json? // string[] — all AMI Cdr dcontext values observed for this linkedId
  channelsSeen           Json? // string[] — accumulated channel names for direction evidence
  rawLegCount            Int       @default(1) // how many CDR notifications were received for this linkedId (channel-leg count)
  isForwarded            Boolean   @default(false) // true for :out rows — inbound call automatically forwarded to an external number (find-me/follow-me)
  recordingPath          String? // deterministic path "YYYY/MM/DD/<linkedId>.wav" computed at ingest; null when call is not recorded
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId, startedAt]) // per-tenant KPI queries
  @@index([startedAt]) // global aggregate queries
  @@index([tenantId, direction, startedAt]) // typed per-tenant KPI queries
}

model Voicemail {
  id             String    @id @default(cuid())
  tenantId       String? // Connect Tenant.id; null = unresolved
  pbxMessageId   String    @unique // stable dedup key: "{pbxTenantId}|{ext}|{origtime}|{callerDigits10}"
  extension      String // mailbox extension number (e.g. "104")
  pbxExtensionId String? // VitalPBX resource ID for this extension
  callerNumber   String?
  callerName     String?
  durationSec    Int       @default(0)
  folder         String    @default("inbox") // normalised: "inbox" | "old" | "urgent"
  pbxFolder      String? // raw PBX folder (e.g. "INBOX", "Old", "Urgent")
  pbxMsgNum      String? // PBX message file basename (e.g. "msg0007")
  pbxRecfile     String? // VitalPBX-relative playback path (e.g. "/static/<tok>/voicemail/<tenant>/<ext>/INBOX/msg0007.wav") — token-authenticated, no app-key needed
  listened       Boolean   @default(false)
  receivedAt     DateTime
  readAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([extension])
  @@index([receivedAt])
  @@index([tenantId, extension, receivedAt])
}

// Admin-configured rules that map DID or extension patterns to VitalPBX tenant slugs.
// Populated via the /admin/cdr/tenant-rules API. Used by CDR ingest to assign tenantId
// when it cannot be resolved from AMI events.
//
// matchType:
//   "did"              — exact match on toNumber (e.g., "8452449666")
//   "from_did"         — exact match on fromNumber (for outgoing calls from a DID)
//   "extension_prefix" — fromNumber starts with this prefix (e.g., "10" matches 100-109)
//
// tenantSlug: VitalPBX tenant name field (e.g., "a_plus_center") — stored without vpbx: prefix.
//             The tenantId written to ConnectCdr will be "vpbx:{tenantSlug}".
model CdrTenantRule {
  id          String   @id @default(cuid())
  matchType   String // "did" | "from_did" | "extension_prefix"
  matchValue  String // the phone number, DID, or prefix
  tenantSlug  String // VitalPBX tenant name (without vpbx: prefix)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([matchType, matchValue])
  @@index([matchType, matchValue])
}

model PbxJob {
  id            String       @id @default(cuid())
  tenantId      String
  pbxInstanceId String?
  type          String
  payload       Json
  status        PbxJobStatus @default(QUEUED)
  attempts      Int          @default(0)
  nextRunAt     DateTime     @default(now())
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pbxInstance   PbxInstance? @relation(fields: [pbxInstanceId], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@index([tenantId, createdAt])
}

model MobileDevice {
  id                    String               @id @default(cuid())
  tenantId              String
  userId                String
  extensionId           String?
  platform              MobilePlatform
  expoPushToken         String               @unique
  voipPushToken         String?
  deviceId              String?
  appVersion            String?
  deviceName            String?
  // Call-wake diagnostics — populated by /mobile/devices/register on every
  // app start so backend can correlate S24 vs S25 vs OnePlus vs Pixel etc.
  manufacturer          String?
  model                 String?
  osVersion             String?
  // Updated by sendPushToUserDevices on every push. Lets the admin /mobile
  // diagnostics surface confirm "yes the push was sent at <ts> and Expo
  // accepted it" or "Expo rejected it with reason X".
  lastPushSentAt        DateTime?
  lastPushType          String?
  lastPushStatus        String?
  lastPushError         String?
  // Runtime-permission snapshot reported by the mobile app on every
  // /mobile/devices/register call. Used by /admin/call-wake-diagnostics
  // to flag devices that are missing RECORD_AUDIO (answer-then-disconnect)
  // or POST_NOTIFICATIONS (no heads-up ringer / lock-screen full-screen
  // intent) without needing the device in hand.
  permRecordAudio       Boolean?
  permNotifications     Boolean?
  permissionsReportedAt DateTime?
  // SipKeepAliveService FGS snapshot reported by the mobile app on every
  // /mobile/devices/register call. Stored as a single JSON blob because the
  // schema is loose (Android-only, may grow as we add more diagnostic
  // fields) and per-row at most ~250 bytes. Powers the FGS health card on
  // /admin/call-wake-diagnostics — primary signal for "calls don't ring on
  // backgrounded S25 / Android 15" (PHONE_CALL FGS rejected by One UI 7).
  keepAliveSnapshot     Json?
  keepAliveReportedAt   DateTime?
  active                Boolean              @default(true)
  deactivatedAt         DateTime?
  lastSeenAt            DateTime             @default(now())
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  extension             Extension?           @relation(fields: [extensionId], references: [id], onDelete: SetNull)
  acceptedInvites       CallInvite[]         @relation("CallInviteAcceptedByDevice")
  voiceClientSessions   VoiceClientSession[]
  callWakeEvents        CallWakeEvent[]      @relation("CallWakeEventByDevice")

  @@index([tenantId, userId])
  @@index([tenantId, platform])
  @@index([tenantId, userId, active])
  @@index([tenantId, lastPushSentAt])
  @@index([extensionId])
}

model MobileProvisioningToken {
