generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String             @id @default(cuid())
  name        String
  createdAt   DateTime           @default(now())
  users       User[]
  tenDlcSubs  TenDlcSubmission[]
  campaigns   SmsCampaign[]
  numbers     PhoneNumber[]
  audits      AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  passwordHash String
  role         String   @default("owner")
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenDlcSubmission {
  id         String   @id @default(cuid())
  tenantId   String
  legalName  String
  status     String   @default("submitted")
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsCampaign {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  message    String
  audience   String
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PhoneNumber {
  id         String   @id @default(cuid())
  tenantId   String
  e164       String
  status     String   @default("purchased")
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  action     String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
EOF
