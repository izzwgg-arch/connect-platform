generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

// ─── CRM Email (Phase 1 — send-only, metadata-first) ───────────────────────────

/// Whether a CrmEmailConnection is owned by a single user or shared at the tenant level.
/// USER  → personal sender. userId is required.
/// TENANT → shared sender (e.g. sales@acme.com). userId is null; managedByUserId is the admin who connected it.
enum CrmEmailConnectionScope {
  USER
  TENANT
}

model CrmEmailConnection {
  id                     String                  @id @default(cuid())
  tenantId               String
  /// USER scope: required (personal sender). TENANT scope: null (shared sender).
  /// Enforced at DB layer via a CHECK constraint added in the migration.
  userId                 String?
  scope                  CrmEmailConnectionScope @default(USER)
  /// For TENANT scope: the admin who created/owns the OAuth grant. Required for TENANT, ignored for USER.
  managedByUserId        String?
  /// At most one TENANT row per (tenantId, provider) may have isDefaultForTenant=true (partial unique index).
  isDefaultForTenant     Boolean                 @default(false)
  /// Optional human label shown in UI (e.g. "Sales Inbox").
  label                  String?
  /// Optional From-header display name. NULL = use Google account's default displayName.
  senderName             String?
  provider               EmailProviderType       @default(GOOGLE_WORKSPACE)
  emailAddress           String
  displayName            String?
  googleAccountId        String?
  encryptedAccessToken   String /// AES-GCM envelope from @connect/security.encryptJson
  encryptedRefreshToken  String /// AES-GCM envelope from @connect/security.encryptJson
  tokenExpiresAt         DateTime?
  scopes                 String[]                @default([])
  replyTrackingEnabled   Boolean                 @default(false)
  gmailHistoryId         String?
  bodyCacheMode          EmailPrivacyMode        @default(METADATA_ONLY)
  bodyCacheRetentionDays Int                     @default(30)
  status                 String                  @default("CONNECTED") /// CONNECTED | ERROR | DISCONNECTED
  lastSyncAt             DateTime?
  lastError              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// User who owns this personal sender (USER scope only). Nullable for TENANT rows.
  user      User?  @relation("CrmEmailConnection_user", fields: [userId], references: [id], onDelete: Cascade)
  /// Admin who manages a TENANT shared sender. Nullable for USER rows.
  managedBy User?  @relation("CrmEmailConnection_managedBy", fields: [managedByUserId], references: [id], onDelete: SetNull)

  // Note: partial unique indexes (USER per tenant+user+provider, single TENANT default per
  // tenant+provider, single TENANT row per tenant+email+provider) are created via raw SQL
  // in the migration. Prisma cannot express partial uniques natively.
  @@index([tenantId, status])
  @@index([tenantId, scope, status])
}

model CrmEmailThread {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  contactId     String?
  gmailThreadId String
  subject       String?
  lastMessageAt DateTime?
  unreadCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact  Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  messages CrmEmailMessage[]

  /// Which CrmEmailConnection actually sent/owns this thread. Null = legacy/unknown.
  senderConnectionId String?

  @@unique([tenantId, gmailThreadId])
  @@index([tenantId, contactId, lastMessageAt])
  @@index([senderConnectionId])
}

model CrmEmailMessage {
  id                 String    @id @default(cuid())
  tenantId           String
  userId             String
  threadId           String?
  contactId          String?
  gmailMessageId     String
  direction          String /// OUTBOUND | INBOUND
  subject            String?
  fromEmail          String?
  toEmail            String?
  cc                 String?
  bcc                String?
  previewSnippet     String?
  aiSummary          String?
  hasCachedBody      Boolean   @default(false)
  bodyCacheEncrypted String?
  bodyCacheExpiresAt DateTime?
  sentAt             DateTime?
  receivedAt         DateTime?
  syncStatus         String?
  createdAt          DateTime  @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread  CrmEmailThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  contact Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Which CrmEmailConnection sent this message. Null = legacy/unknown.
  senderConnectionId String?

  @@unique([tenantId, gmailMessageId])
  @@index([threadId, createdAt])
  @@index([tenantId, hasCachedBody, bodyCacheExpiresAt])
  @@index([senderConnectionId])
}

model CrmEmailSendLog {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  contactId      String?
  templateId     String?
  gmailMessageId String?
  gmailThreadId  String?
  toEmail        String
  subject        String?
  status         String   @default("SENT") /// SENT | FAILED
  errorMessage   String?
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  /// Which CrmEmailConnection sent this. Null = legacy/unknown.
  senderConnectionId String?

  @@index([tenantId, userId, sentAt])
  @@index([tenantId, gmailMessageId])
  @@index([senderConnectionId])
}

/// CRM Email Template — Phase 1. Tenant-scoped, optionally user-scoped (private).
/// Body is plain text; merge fields use {{contact.firstName}} style tokens.
model CrmEmailTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String?
  name            String
  subject         String
  bodyText        String
  /// SHARED across tenant or PRIVATE to creator.
  visibility      String   @default("SHARED")
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, isArchived, updatedAt])
  @@index([tenantId, createdByUserId])
}

