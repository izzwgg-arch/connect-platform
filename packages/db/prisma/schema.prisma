generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenDlcStatus {
  DRAFT
  SUBMITTED
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  PAUSED
  NEEDS_APPROVAL
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
}

enum IntegrationProvider {
  TWILIO
  VOIPMS
}

enum SmsSendMode {
  TEST
  LIVE
}

enum SmsProviderRoutingMode {
  SINGLE_PRIMARY
  FAILOVER
}

enum PhoneNumberProvider {
  TWILIO
  VOIPMS
}

enum WhatsAppProviderType {
  WHATSAPP_TWILIO
  WHATSAPP_META
}

enum EmailProviderType {
  SENDGRID
  SMTP
  GOOGLE_WORKSPACE
}

enum InvoiceStatus {
  DRAFT
  SENT
  OVERDUE
  PAID
  VOID
}

enum EmailJobStatus {
  QUEUED
  RUNNING
  SENT
  FAILED
}

enum PhoneNumberStatus {
  ACTIVE
  RELEASING
  RELEASED
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  PENDING
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SolaConfigMode {
  SANDBOX
  PROD
}

enum SolaAuthMode {
  XKEY_BODY
  AUTHORIZATION_HEADER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  FAILED
  OVERDUE
  VOID
}

enum BillingLineItemType {
  EXTENSION
  PHONE_NUMBER
  SMS_PACKAGE
  SALES_TAX
  E911_FEE
  REGULATORY_FEE
  CREDIT
  DISCOUNT
  MANUAL_ADJUSTMENT
}

enum BillingPaymentMethodProcessor {
  SOLA
}

enum BillingPaymentTransactionStatus {
  PENDING
  APPROVED
  DECLINED
  ERROR
  VOIDED
  REFUNDED
}

enum BillingRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum PbxLinkStatus {
  LINKED
  UNLINKED
  ERROR
}

enum PbxRouteType {
  MAIN_IVR
  RING_GROUP
  QUEUE
  EXTENSION
  CUSTOM
}

enum PbxJobStatus {
  QUEUED
  RUNNING
  FAILED
  COMPLETED
}

enum DtmfMode {
  RFC2833
  SIP_INFO
}

enum MobilePlatform {
  IOS
  ANDROID
}

enum TurnValidationStatus {
  UNKNOWN
  VERIFIED
  FAILED
  STALE
}

enum TurnConfigScope {
  GLOBAL
  TENANT
}

enum TurnValidationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum VoiceClientPlatform {
  WEB
  IOS
  ANDROID
}

enum VoiceDiagRegState {
  IDLE
  REGISTERING
  REGISTERED
  FAILED
}

enum VoiceDiagCallState {
  IDLE
  DIALING
  RINGING
  CONNECTED
  ENDED
}

enum VoiceDiagEventType {
  SESSION_START
  SESSION_HEARTBEAT
  SIP_REGISTER
  SIP_UNREGISTER
  WS_CONNECTED
  WS_DISCONNECTED
  WS_RECONNECT
  ICE_GATHERING
  ICE_SELECTED_PAIR
  TURN_TEST_RESULT
  INCOMING_INVITE
  ANSWER_TAPPED
  CALL_CONNECTED
  CALL_ENDED
  ERROR
  MEDIA_TEST_RUN
  CALL_QUALITY_REPORT
}

enum MediaTestStatus {
  UNKNOWN
  PASSED
  FAILED
  STALE
}

enum MediaTestRunStatus {
  QUEUED
  PASSED
  FAILED
}

enum MediaPolicy {
  TURN_ONLY
  RTPENGINE_PREFERRED
}

enum SbcMode {
  LOCAL
  REMOTE
}

enum CallInviteStatus {
  PENDING
  ACCEPTED
  HELD
  DECLINED
  EXPIRED
  CANCELED
}

model Tenant {
  id                              String                    @id @default(cuid())
  name                            String
  isApproved                      Boolean                   @default(false)
  dailySmsCap                     Int                       @default(100)
  perSecondRate                   Float                     @default(1.0)
  firstCampaignRequiresApproval   Boolean                   @default(true)
  smsSendMode                     SmsSendMode               @default(TEST)
  smsLiveEnabledAt                DateTime?
  smsLiveEnabledByUserId          String?
  dailySmsLimit                   Int                       @default(500)
  hourlySmsLimit                  Int                       @default(100)
  perSecondRateLimit              Int                       @default(5)
  maxCampaignSize                 Int                       @default(2000)
  smsSuspended                    Boolean                   @default(false)
  smsSuspendedReason              String?
  smsSuspendedAt                  DateTime?
  smsRoutingMode                  SmsProviderRoutingMode    @default(FAILOVER)
  smsPrimaryProvider              IntegrationProvider       @default(TWILIO)
  smsSecondaryProvider            IntegrationProvider?      @default(VOIPMS)
  smsProviderLock                 IntegrationProvider?
  smsProviderLockReason           String?
  smsProviderLockedAt             DateTime?
  smsProviderLockedByUserId       String?
  defaultSmsFromNumberId          String?
  defaultVoiceFromNumberId        String?
  numberPurchaseEnabled           Boolean                   @default(true)
  smsSubscriptionRequired         Boolean                   @default(true)
  smsBillingEnforced              Boolean                   @default(true)
  webrtcEnabled                   Boolean                   @default(false)
  webrtcRouteViaSbc               Boolean                   @default(false)
  sipWsUrl                        String?
  sipDomain                       String?
  iceServers                      Json?
  outboundProxy                   String?
  dtmfMode                        DtmfMode                  @default(RFC2833)
  turnRequiredForMobile           Boolean                   @default(false)
  turnValidationStatus            TurnValidationStatus      @default(UNKNOWN)
  turnValidatedAt                 DateTime?
  turnLastErrorCode               String?
  turnLastErrorAt                 DateTime?
  mediaReliabilityGateEnabled     Boolean                   @default(false)
  mediaTestStatus                 MediaTestStatus           @default(UNKNOWN)
  mediaTestedAt                   DateTime?
  mediaLastErrorCode              String?
  mediaLastErrorAt                DateTime?
  mediaPolicy                     MediaPolicy               @default(TURN_ONLY)
  sbcUdpExposureConfirmed         Boolean                   @default(false)
  sbcUdpExposureConfirmedAt       DateTime?
  sbcUdpExposureConfirmedByUserId String?
  createdAt                       DateTime                  @default(now())
  users                           User[]
  tenDlcSubs                      TenDlcSubmission[]
  campaigns                       SmsCampaign[]
  numbers                         PhoneNumber[]             @relation("TenantOwnedNumbers")
  audits                          AuditLog[]
  providerCredentials             ProviderCredential[]
  billingSolaConfig               BillingSolaConfig?
  whatsappProviderConfigs         WhatsAppProviderConfig[]
  whatsAppThreads                 WhatsAppThread[]
  whatsAppMessages                WhatsAppMessage[]
  emailProviderConfig             EmailProviderConfig?
  webhookEvents                   SmsWebhookEvent[]
  providerHealth                  ProviderHealth[]
  subscription                    Subscription?
  paymentEvents                   PaymentEvent[]
  usageLedger                     UsageLedger[]
  receipts                        Receipt[]
  invoices                        Invoice[]
  billingPlan                     BillingPlan?
  billingSettings                 TenantBillingSettings?
  billingInvoices                 BillingInvoice[]
  paymentMethods                  PaymentMethod[]
  paymentTransactions             PaymentTransaction[]
  billingRuns                     BillingRun[]
  billingEventLogs                BillingEventLog[]
  customers                       Customer[]
  contacts                        Contact[]
  contactTags                     ContactTag[]
  customerNotes                   CustomerNote[]
  customerTasks                   CustomerTask[]
  automationRules                 AutomationRule[]
  invoiceEvents                   InvoiceEvent[]
  emailJobs                       EmailJob[]
  alerts                          Alert[]
  extensions                      Extension[]
  callRecords                     CallRecord[]
  mobileDevices                   MobileDevice[]
  callInvites                     CallInvite[]
  voiceClientSessions             VoiceClientSession[]
  voiceDiagEvents                 VoiceDiagEvent[]
  mediaTestRuns                   MediaTestRun[]
  turnConfigs                     TurnConfig[]
  turnValidationJobs              TurnValidationJob[]
  mobileProvisioningTokens        MobileProvisioningToken[]
  pbxTenantLink                   TenantPbxLink?
  pbxExtensionLinks               PbxExtensionLink[]
  pbxDidLinks                     PbxDidLink[]
  pbxCdrCursor                    PbxCdrCursor?
  pbxJobs                         PbxJob[]
  ivrSchedules                    IvrSchedule[]
  ivrRouteProfiles                IvrRouteProfile[]
  ivrOptionRoutes                 IvrOptionRoute[]
  pbxPrompts                      TenantPbxPrompt[]
  ivrScheduleConfig               IvrScheduleConfig?
  ivrOverrideState                IvrOverrideState?
  ivrPublishRecords               IvrPublishRecord[]
  mohProfiles                     MohProfile[]
  mohScheduleConfig               MohScheduleConfig?
  mohOverrideState                MohOverrideState?
  mohPublishRecords               MohPublishRecord[]
  mohLastPublishedState           MohLastPublishedState?
  didRouteMappings                DidRouteMapping[]
  mohAssets                       MohAsset[]
  pbxMohClasses                   PbxMohClass[]
  pbxCallEvents                   PbxCallEvent[]
  smsLiveEnabledByUser            User?                     @relation("TenantSmsLiveEnabledBy", fields: [smsLiveEnabledByUserId], references: [id], onDelete: SetNull)
  smsProviderLockedByUser         User?                     @relation("TenantSmsProviderLockedBy", fields: [smsProviderLockedByUserId], references: [id], onDelete: SetNull)
  defaultSmsFromNumber            PhoneNumber?              @relation("TenantDefaultSmsFromNumber", fields: [defaultSmsFromNumberId], references: [id], onDelete: SetNull)
  tenantSmsNumbers                TenantSmsNumber[]
  connectChatThreads              ConnectChatThread[]
  smsRoutingLogs                  SmsRoutingLog[]
}

model User {
  id                             String                    @id @default(cuid())
  tenantId                       String
  email                          String                    @unique
  passwordHash                   String
  role                           UserRole                  @default(USER)
  createdAt                      DateTime                  @default(now())
  tenant                         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents                    AuditLog[]                @relation("AuditActor")
  createdProviderCredentials     ProviderCredential[]      @relation("ProviderCredentialCreatedBy")
  updatedProviderCredentials     ProviderCredential[]      @relation("ProviderCredentialUpdatedBy")
  createdBillingSolaConfigs      BillingSolaConfig[]       @relation("BillingSolaConfigCreatedBy")
  updatedBillingSolaConfigs      BillingSolaConfig[]       @relation("BillingSolaConfigUpdatedBy")
  createdWhatsAppProviderConfigs WhatsAppProviderConfig[]  @relation("WhatsAppProviderConfigCreatedBy")
  updatedWhatsAppProviderConfigs WhatsAppProviderConfig[]  @relation("WhatsAppProviderConfigUpdatedBy")
  createdEmailProviderConfigs    EmailProviderConfig[]     @relation("EmailProviderConfigCreatedBy")
  updatedEmailProviderConfigs    EmailProviderConfig[]     @relation("EmailProviderConfigUpdatedBy")
  smsLiveEnabledTenants          Tenant[]                  @relation("TenantSmsLiveEnabledBy")
  smsProviderLockedTenants       Tenant[]                  @relation("TenantSmsProviderLockedBy")
  ownedExtensions                Extension[]               @relation("ExtensionOwner")
  mobileDevices                  MobileDevice[]
  callInvites                    CallInvite[]
  voiceClientSessions            VoiceClientSession[]
  voiceDiagEvents                VoiceDiagEvent[]
  requestedTurnValidationJobs    TurnValidationJob[]       @relation("TurnValidationRequestedBy")
  requestedMediaTestRuns         MediaTestRun[]            @relation("MediaTestRequestedBy")
  mobileProvisioningTokens       MobileProvisioningToken[]
  updatedSbcConfigs              SbcConfig[]               @relation("SbcConfigUpdatedBy")
  customerNotes                  CustomerNote[]
  createdContacts                Contact[]                 @relation("ContactCreatedBy")
  createdCustomerTasks           CustomerTask[]            @relation("CustomerTaskCreatedBy")
  completedCustomerTasks         CustomerTask[]            @relation("CustomerTaskCompletedBy")
  createdAutomationRules         AutomationRule[]          @relation("AutomationRuleCreatedBy")
  tenantSmsNumbersAssigned       TenantSmsNumber[]         @relation("TenantSmsNumberAssignUser")
  connectChatParticipants        ConnectChatParticipant[]
  connectChatMessages            ConnectChatMessage[]      @relation("ConnectChatMessageSenderUser")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BILLING
  MESSAGING
  SUPPORT
  READ_ONLY
  USER
}

enum CustomerStatus {
  ACTIVE
  PAST_DUE
  INACTIVE
}

enum ContactType {
  INTERNAL_EXTENSION
  EXTERNAL
  COMPANY
}

enum ContactSource {
  MANUAL
  EXTENSION
  IMPORTED
}

enum ContactPhoneType {
  MOBILE
  OFFICE
  HOME
  OTHER
}

enum ContactEmailType {
  WORK
  PERSONAL
  OTHER
}

enum CustomerTaskStatus {
  OPEN
  DONE
}

enum CustomerTaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Subscription {
  id                      String             @id @default(cuid())
  tenantId                String             @unique
  planCode                String
  priceCents              Int
  currency                String             @default("USD")
  status                  SubscriptionStatus @default(NONE)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  provider                String             @default("SOLA_CARDKNOX")
  providerCustomerId      String?
  providerSubscriptionId  String?
  providerPaymentMethodId String?
  billingEmail            String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  paymentMethodExpMonth   String?
  paymentMethodExpYear    String?
  lastPaymentStatus       PaymentStatus?
  lastPaymentAt           DateTime?
  lastFailureReason       String?
  pastDueSince            DateTime?
  retryCount              Int                @default(0)
  nextRetryAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentEvents           PaymentEvent[]
  receipts                Receipt[]
}

model PaymentEvent {
  id              String        @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  provider        String
  providerEventId String?
  type            String
  status          PaymentStatus
  amountCents     Int?
  currency        String?
  payload         Json
  receivedAt      DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([tenantId, receivedAt])
}

model UsageLedger {
  id             String   @id @default(cuid())
  tenantId       String
  type           String
  quantity       Int      @default(1)
  unitPriceCents Int
  totalCents     Int
  referenceId    String?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
}

model BillingPlan {
  id                              String                  @id @default(cuid())
  tenantId                        String?                 @unique
  code                            String                  @unique
  name                            String
  extensionPriceCents             Int                     @default(3000)
  additionalPhoneNumberPriceCents Int                     @default(1000)
  smsPriceCents                   Int                     @default(1000)
  firstPhoneNumberFree            Boolean                 @default(true)
  active                          Boolean                 @default(true)
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  tenant                          Tenant?                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantSettings                  TenantBillingSettings[]

  @@index([active, code])
}

model TaxProfile {
  id                     String                  @id @default(cuid())
  name                   String
  state                  String
  county                 String?
  salesTaxRate           Decimal                 @default(0) @db.Decimal(7, 6)
  e911FeePerExtension    Int                     @default(0)
  regulatoryFeePercent   Decimal                 @default(0) @db.Decimal(7, 6)
  regulatoryFeeEnabled   Boolean                 @default(true)
  enabled                Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  tenantBillingSettings  TenantBillingSettings[]

  @@unique([state, county])
  @@index([enabled, state, county])
}

model TenantBillingSettings {
  id                              String          @id @default(cuid())
  tenantId                        String          @unique
  billingPlanId                   String?
  extensionPriceCents             Int             @default(3000)
  additionalPhoneNumberPriceCents Int             @default(1000)
  smsPriceCents                   Int             @default(1000)
  firstPhoneNumberFree            Boolean         @default(true)
  smsBillingEnabled               Boolean         @default(false)
  taxEnabled                      Boolean         @default(false)
  taxProfileId                    String?
  autoBillingEnabled              Boolean         @default(false)
  billingDayOfMonth               Int             @default(1)
  paymentTermsDays                Int             @default(15)
  defaultPaymentMethodId          String?
  billingEmail                    String?
  billingAddress                  Json?
  serviceAddress                  Json?
  creditsCents                    Int             @default(0)
  discountPercent                 Decimal         @default(0) @db.Decimal(7, 6)
  metadata                        Json?
  createdAt                       DateTime        @default(now())
  updatedAt                       DateTime        @updatedAt
  tenant                          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billingPlan                     BillingPlan?    @relation(fields: [billingPlanId], references: [id], onDelete: SetNull)
  taxProfile                      TaxProfile?     @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)
  defaultPaymentMethod            PaymentMethod?  @relation("DefaultTenantBillingPaymentMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)

  @@index([taxProfileId])
  @@index([autoBillingEnabled, billingDayOfMonth])
}

model BillingInvoice {
  id                    String                    @id @default(cuid())
  tenantId              String
  invoiceNumber         String                    @unique
  status                BillingInvoiceStatus      @default(DRAFT)
  currency              String                    @default("USD")
  periodStart           DateTime
  periodEnd             DateTime
  issueDate             DateTime                  @default(now())
  dueDate               DateTime
  subtotalCents         Int                       @default(0)
  taxCents              Int                       @default(0)
  totalCents            Int                       @default(0)
  amountPaidCents       Int                       @default(0)
  balanceDueCents       Int                       @default(0)
  paymentMethodId       String?
  paidAt                DateTime?
  failedAt              DateTime?
  voidedAt              DateTime?
  lastEmailStatus       String?
  lastEmailedAt         DateTime?
  pdfStorageKey         String?
  pdfGeneratedAt        DateTime?
  notes                 String?
  metadata              Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentMethod         PaymentMethod?            @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  lineItems             BillingInvoiceLineItem[]
  transactions          PaymentTransaction[]
  events                BillingEventLog[]

  @@index([tenantId, status, dueDate])
  @@index([tenantId, periodStart, periodEnd])
  @@index([createdAt])
}

model BillingInvoiceLineItem {
  id              String              @id @default(cuid())
  invoiceId       String
  tenantId        String
  type            BillingLineItemType
  description     String
  quantity        Int                 @default(1)
  unitPriceCents  Int                 @default(0)
  amountCents     Int
  taxable         Boolean             @default(true)
  metadata        Json?
  createdAt       DateTime            @default(now())
  invoice         BillingInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([tenantId, type])
}

model PaymentMethod {
  id                         String                          @id @default(cuid())
  tenantId                   String
  processor                  BillingPaymentMethodProcessor   @default(SOLA)
  tokenEncrypted             String
  tokenKeyId                 String                          @default("v1")
  brand                      String?
  last4                      String?
  expMonth                   String?
  expYear                    String?
  cardholderName             String?
  billingZip                 String?
  isDefault                  Boolean                         @default(false)
  active                     Boolean                         @default(true)
  lastUsedAt                 DateTime?
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt
  tenant                     Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultForBillingSettings  TenantBillingSettings[]         @relation("DefaultTenantBillingPaymentMethod")
  invoices                   BillingInvoice[]
  transactions               PaymentTransaction[]

  @@index([tenantId, active])
  @@index([tenantId, isDefault])
}

model PaymentTransaction {
  id                      String                          @id @default(cuid())
  tenantId                String
  invoiceId               String?
  paymentMethodId         String?
  amountCents             Int
  currency                String                          @default("USD")
  status                  BillingPaymentTransactionStatus @default(PENDING)
  processor               BillingPaymentMethodProcessor   @default(SOLA)
  processorTransactionId  String?
  responseCode            String?
  responseMessage         String?
  rawResponseSafeJson     Json?
  idempotencyKey          String?                         @unique
  createdAt               DateTime                        @default(now())
  updatedAt               DateTime                        @updatedAt
  tenant                  Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice                 BillingInvoice?                 @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentMethod           PaymentMethod?                  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([invoiceId, createdAt])
  @@index([processor, processorTransactionId])
}

model BillingRun {
  id               String             @id @default(cuid())
  tenantId         String?
  periodStart      DateTime
  periodEnd        DateTime
  status           BillingRunStatus   @default(RUNNING)
  dryRun           Boolean            @default(false)
  totals           Json?
  errorMessage     String?
  startedAt        DateTime           @default(now())
  finishedAt       DateTime?
  createdAt        DateTime           @default(now())
  tenant           Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  events           BillingEventLog[]

  @@index([status, startedAt])
  @@index([tenantId, startedAt])
}

model BillingEventLog {
  id          String          @id @default(cuid())
  tenantId    String
  invoiceId   String?
  runId       String?
  type        String
  message     String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     BillingInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  run         BillingRun?     @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([invoiceId, createdAt])
  @@index([runId, createdAt])
}

model TenDlcSubmission {
  id                    String       @id @default(cuid())
  tenantId              String
  legalName             String
  dba                   String?
  einEncrypted          String
  businessType          String
  websiteUrl            String
  addressStreet         String
  addressCity           String
  addressState          String
  addressPostalCode     String
  addressCountry        String
  supportEmail          String
  supportPhone          String
  useCaseCategory       String
  sampleMessage1        String
  sampleMessage2        String
  sampleMessage3        String
  optInMethod           String
  optInWorkflow         String
  optInProofUrl         String?
  messagesPerDay        Int
  messagesPerMonth      Int
  includesEmbeddedLinks Boolean
  includesPhoneNumbers  Boolean
  includesAffiliateMktg Boolean
  ageGatedContent       Boolean
  termsAccepted         Boolean
  signatureName         String
  signatureDate         DateTime
  status                TenDlcStatus @default(SUBMITTED)
  internalNotes         String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime     @default(now())
  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsCampaign {
  id               String         @id @default(cuid())
  tenantId         String
  name             String
  message          String
  fromNumber       String
  audienceType     String
  requiresApproval Boolean        @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  holdReason       String?
  riskScore        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages         SmsMessage[]
}

model SmsMessage {
  id                   String               @id @default(cuid())
  campaignId           String
  toNumber             String
  fromNumber           String
  fromNumberId         String?
  body                 String
  status               SmsMessageStatus     @default(QUEUED)
  providerMessageId    String?
  providerStatus       String?
  provider             IntegrationProvider?
  providerErrorCode    String?
  providerAttemptedAt  DateTime?
  providerRoute        String?
  lastProviderUpdateAt DateTime?
  deliveryUpdatedAt    DateTime?
  error                String?
  createdAt            DateTime             @default(now())
  sentAt               DateTime?
  campaign             SmsCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromNumberRef        PhoneNumber?         @relation("SmsMessageFromNumber", fields: [fromNumberId], references: [id], onDelete: SetNull)
  webhookEvents        SmsWebhookEvent[]
}

model SmsWebhookEvent {
  id                String              @id @default(cuid())
  tenantId          String?
  provider          IntegrationProvider
  messageId         String?
  providerMessageId String
  eventType         String
  payload           Json
  receivedAt        DateTime            @default(now())
  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  message           SmsMessage?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([provider, providerMessageId])
  @@index([tenantId, receivedAt])
}

model ProviderHealth {
  id               String              @id @default(cuid())
  tenantId         String
  provider         IntegrationProvider
  windowStart      DateTime
  sentCount        Int                 @default(0)
