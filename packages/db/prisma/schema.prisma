generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenDlcStatus {
  DRAFT
  SUBMITTED
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  PAUSED
  NEEDS_APPROVAL
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
}

enum IntegrationProvider {
  TWILIO
  VOIPMS
}

enum SmsSendMode {
  TEST
  LIVE
}

enum SmsProviderRoutingMode {
  SINGLE_PRIMARY
  FAILOVER
}

enum PhoneNumberProvider {
  TWILIO
  VOIPMS
}

enum PhoneNumberStatus {
  ACTIVE
  RELEASING
  RELEASED
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  PENDING
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum PbxLinkStatus {
  LINKED
  UNLINKED
  ERROR
}

enum PbxRouteType {
  MAIN_IVR
  RING_GROUP
  QUEUE
  EXTENSION
  CUSTOM
}

enum PbxJobStatus {
  QUEUED
  RUNNING
  FAILED
  COMPLETED
}

enum DtmfMode {
  RFC2833
  SIP_INFO
}

enum MobilePlatform {
  IOS
  ANDROID
}

enum TurnValidationStatus {
  UNKNOWN
  VERIFIED
  FAILED
  STALE
}

enum TurnConfigScope {
  GLOBAL
  TENANT
}

enum TurnValidationJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum VoiceClientPlatform {
  WEB
  IOS
  ANDROID
}

enum VoiceDiagRegState {
  IDLE
  REGISTERING
  REGISTERED
  FAILED
}

enum VoiceDiagCallState {
  IDLE
  DIALING
  RINGING
  CONNECTED
  ENDED
}

enum VoiceDiagEventType {
  SESSION_START
  SESSION_HEARTBEAT
  SIP_REGISTER
  SIP_UNREGISTER
  WS_CONNECTED
  WS_DISCONNECTED
  WS_RECONNECT
  ICE_GATHERING
  ICE_SELECTED_PAIR
  TURN_TEST_RESULT
  INCOMING_INVITE
  ANSWER_TAPPED
  CALL_CONNECTED
  CALL_ENDED
  ERROR
  MEDIA_TEST_RUN
}

enum MediaTestStatus {
  UNKNOWN
  PASSED
  FAILED
  STALE
}

enum MediaTestRunStatus {
  QUEUED
  PASSED
  FAILED
}

enum MediaPolicy {
  TURN_ONLY
  RTPENGINE_PREFERRED
}

enum CallInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELED
}

model Tenant {
  id                            String                 @id @default(cuid())
  name                          String
  isApproved                    Boolean                @default(false)
  dailySmsCap                   Int                    @default(100)
  perSecondRate                 Float                  @default(1.0)
  firstCampaignRequiresApproval Boolean                @default(true)
  smsSendMode                   SmsSendMode            @default(TEST)
  smsLiveEnabledAt              DateTime?
  smsLiveEnabledByUserId        String?
  dailySmsLimit                 Int                    @default(500)
  hourlySmsLimit                Int                    @default(100)
  perSecondRateLimit            Int                    @default(5)
  maxCampaignSize               Int                    @default(2000)
  smsSuspended                  Boolean                @default(false)
  smsSuspendedReason            String?
  smsSuspendedAt                DateTime?
  smsRoutingMode                SmsProviderRoutingMode @default(FAILOVER)
  smsPrimaryProvider            IntegrationProvider    @default(TWILIO)
  smsSecondaryProvider          IntegrationProvider?   @default(VOIPMS)
  smsProviderLock               IntegrationProvider?
  smsProviderLockReason         String?
  smsProviderLockedAt           DateTime?
  smsProviderLockedByUserId     String?
  defaultSmsFromNumberId        String?
  defaultVoiceFromNumberId      String?
  numberPurchaseEnabled         Boolean                @default(true)
  smsSubscriptionRequired       Boolean                @default(true)
  smsBillingEnforced            Boolean                @default(true)
  webrtcEnabled                 Boolean                @default(false)
  webrtcRouteViaSbc             Boolean                @default(false)
  sipWsUrl                      String?
  sipDomain                     String?
  iceServers                    Json?
  outboundProxy                 String?
  dtmfMode                      DtmfMode               @default(RFC2833)
  turnRequiredForMobile         Boolean                @default(false)
  turnValidationStatus          TurnValidationStatus   @default(UNKNOWN)
  turnValidatedAt               DateTime?
  turnLastErrorCode             String?
  turnLastErrorAt               DateTime?
  mediaReliabilityGateEnabled   Boolean                @default(false)
  mediaTestStatus               MediaTestStatus        @default(UNKNOWN)
  mediaTestedAt                 DateTime?
  mediaLastErrorCode            String?
  mediaLastErrorAt              DateTime?
  mediaPolicy                  MediaPolicy            @default(TURN_ONLY)
  sbcUdpExposureConfirmed      Boolean                @default(false)
  sbcUdpExposureConfirmedAt    DateTime?
  sbcUdpExposureConfirmedByUserId String?
  createdAt                     DateTime               @default(now())
  users                         User[]
  tenDlcSubs                    TenDlcSubmission[]
  campaigns                     SmsCampaign[]
  numbers                       PhoneNumber[]          @relation("TenantOwnedNumbers")
  audits                        AuditLog[]
  providerCredentials           ProviderCredential[]
  webhookEvents                 SmsWebhookEvent[]
  providerHealth                ProviderHealth[]
  subscription                  Subscription?
  paymentEvents                 PaymentEvent[]
  usageLedger                   UsageLedger[]
  receipts                      Receipt[]
  alerts                        Alert[]
  extensions                    Extension[]
  callRecords                   CallRecord[]
  mobileDevices                 MobileDevice[]
  callInvites                   CallInvite[]
  voiceClientSessions           VoiceClientSession[]
  voiceDiagEvents               VoiceDiagEvent[]
  mediaTestRuns                 MediaTestRun[]
  turnConfigs                   TurnConfig[]
  turnValidationJobs            TurnValidationJob[]
  mobileProvisioningTokens      MobileProvisioningToken[]
  pbxTenantLink                 TenantPbxLink?
  pbxExtensionLinks             PbxExtensionLink[]
  pbxDidLinks                   PbxDidLink[]
  pbxCdrCursor                  PbxCdrCursor?
  pbxJobs                       PbxJob[]
  smsLiveEnabledByUser          User?                  @relation("TenantSmsLiveEnabledBy", fields: [smsLiveEnabledByUserId], references: [id], onDelete: SetNull)
  smsProviderLockedByUser       User?                  @relation("TenantSmsProviderLockedBy", fields: [smsProviderLockedByUserId], references: [id], onDelete: SetNull)
  defaultSmsFromNumber          PhoneNumber?           @relation("TenantDefaultSmsFromNumber", fields: [defaultSmsFromNumberId], references: [id], onDelete: SetNull)
}

model User {
  id                         String               @id @default(cuid())
  tenantId                   String
  email                      String               @unique
  passwordHash               String
  role                       String               @default("USER")
  createdAt                  DateTime             @default(now())
  tenant                     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents                AuditLog[]           @relation("AuditActor")
  createdProviderCredentials ProviderCredential[] @relation("ProviderCredentialCreatedBy")
  updatedProviderCredentials ProviderCredential[] @relation("ProviderCredentialUpdatedBy")
  smsLiveEnabledTenants      Tenant[]             @relation("TenantSmsLiveEnabledBy")
  smsProviderLockedTenants   Tenant[]             @relation("TenantSmsProviderLockedBy")
  ownedExtensions            Extension[]          @relation("ExtensionOwner")
  mobileDevices              MobileDevice[]
  callInvites                CallInvite[]
  voiceClientSessions        VoiceClientSession[]
  voiceDiagEvents            VoiceDiagEvent[]
  requestedTurnValidationJobs TurnValidationJob[] @relation("TurnValidationRequestedBy")
  requestedMediaTestRuns     MediaTestRun[]      @relation("MediaTestRequestedBy")
  mobileProvisioningTokens    MobileProvisioningToken[]
}

model Subscription {
  id                      String             @id @default(cuid())
  tenantId                String             @unique
  planCode                String
  priceCents              Int
  currency                String             @default("USD")
  status                  SubscriptionStatus @default(NONE)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  provider                String             @default("SOLA_CARDKNOX")
  providerCustomerId      String?
  providerSubscriptionId  String?
  providerPaymentMethodId String?
  billingEmail            String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  paymentMethodExpMonth   String?
  paymentMethodExpYear    String?
  lastPaymentStatus       PaymentStatus?
  lastPaymentAt           DateTime?
  lastFailureReason       String?
  pastDueSince            DateTime?
  retryCount              Int                @default(0)
  nextRetryAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentEvents           PaymentEvent[]
  receipts                Receipt[]
}

model PaymentEvent {
  id              String        @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  provider        String
  providerEventId String?
  type            String
  status          PaymentStatus
  amountCents     Int?
  currency        String?
  payload         Json
  receivedAt      DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([tenantId, receivedAt])
}

model UsageLedger {
  id             String   @id @default(cuid())
  tenantId       String
  type           String
  quantity       Int      @default(1)
  unitPriceCents Int
  totalCents     Int
  referenceId    String?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
}

model TenDlcSubmission {
  id                    String       @id @default(cuid())
  tenantId              String
  legalName             String
  dba                   String?
  einEncrypted          String
  businessType          String
  websiteUrl            String
  addressStreet         String
  addressCity           String
  addressState          String
  addressPostalCode     String
  addressCountry        String
  supportEmail          String
  supportPhone          String
  useCaseCategory       String
  sampleMessage1        String
  sampleMessage2        String
  sampleMessage3        String
  optInMethod           String
  optInWorkflow         String
  optInProofUrl         String?
  messagesPerDay        Int
  messagesPerMonth      Int
  includesEmbeddedLinks Boolean
  includesPhoneNumbers  Boolean
  includesAffiliateMktg Boolean
  ageGatedContent       Boolean
  termsAccepted         Boolean
  signatureName         String
  signatureDate         DateTime
  status                TenDlcStatus @default(SUBMITTED)
  internalNotes         String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime     @default(now())
  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsCampaign {
  id               String         @id @default(cuid())
  tenantId         String
  name             String
  message          String
  fromNumber       String
  audienceType     String
  requiresApproval Boolean        @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  holdReason       String?
  riskScore        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages         SmsMessage[]
}

model SmsMessage {
  id                   String               @id @default(cuid())
  campaignId           String
  toNumber             String
  fromNumber           String
  fromNumberId         String?
  body                 String
  status               SmsMessageStatus     @default(QUEUED)
  providerMessageId    String?
  providerStatus       String?
  provider             IntegrationProvider?
  providerErrorCode    String?
  providerAttemptedAt  DateTime?
  providerRoute        String?
  lastProviderUpdateAt DateTime?
  deliveryUpdatedAt    DateTime?
  error                String?
  createdAt            DateTime             @default(now())
  sentAt               DateTime?
  campaign             SmsCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromNumberRef        PhoneNumber?         @relation("SmsMessageFromNumber", fields: [fromNumberId], references: [id], onDelete: SetNull)
  webhookEvents        SmsWebhookEvent[]
}

model SmsWebhookEvent {
  id                String              @id @default(cuid())
  tenantId          String?
  provider          IntegrationProvider
  messageId         String?
  providerMessageId String
  eventType         String
  payload           Json
  receivedAt        DateTime            @default(now())
  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  message           SmsMessage?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([provider, providerMessageId])
  @@index([tenantId, receivedAt])
}

model ProviderHealth {
  id               String              @id @default(cuid())
  tenantId         String
  provider         IntegrationProvider
  windowStart      DateTime
  sentCount        Int                 @default(0)
  failCount        Int                 @default(0)
  lastErrorCode    String?
  lastErrorAt      DateTime?
  circuitOpenUntil DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, windowStart])
  @@index([tenantId, provider])
}

model PhoneNumber {
  id                String              @id @default(cuid())
  tenantId          String
  provider          PhoneNumberProvider
  phoneNumber       String              @unique
  providerId        String?
  friendlyName      String?
  capabilities      Json?
  region            String?
  areaCode          String?
  monthlyCostCents  Int?
  status            PhoneNumberStatus   @default(ACTIVE)
  purchasedAt       DateTime            @default(now())
  releasedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenant            Tenant              @relation("TenantOwnedNumbers", fields: [tenantId], references: [id], onDelete: Cascade)
  defaultForTenants Tenant[]            @relation("TenantDefaultSmsFromNumber")
  smsMessages       SmsMessage[]        @relation("SmsMessageFromNumber")
  pbxDidLinks       PbxDidLink[]

  @@index([tenantId, status])
  @@index([provider, status])
}

model ProviderCredential {
  id                   String              @id @default(cuid())
  tenantId             String
  provider             IntegrationProvider
  label                String?
  isEnabled            Boolean             @default(false)
  credentialsEncrypted String
  credentialsKeyId     String              @default("v1")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User                @relation("ProviderCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User                @relation("ProviderCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, provider])
}

model AuditLog {
  id          String               @id @default(cuid())
  tenantId    String
  action      String
  entityType  String
  entityId    String
  actorUserId String?
  provider    IntegrationProvider?
  createdAt   DateTime             @default(now())
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser   User?                @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}

model Receipt {
  id             String       @id @default(cuid())
  tenantId       String
  subscriptionId String
  amountCents    Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model Alert {
  id             String    @id @default(cuid())
  tenantId       String
  severity       String
  category       String
  message        String
  metadata       Json?
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
}

model Extension {
  id          String            @id @default(cuid())
  tenantId    String
  extNumber   String
  displayName String
  ownerUserId String?
  status      String            @default("ACTIVE")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerUser   User?             @relation("ExtensionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  pbxLink     PbxExtensionLink?
  callInvites CallInvite[]

  @@unique([tenantId, extNumber])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
}

model PbxInstance {
  id               String          @id @default(cuid())
  name             String
  baseUrl          String
  apiAuthEncrypted String
  isEnabled        Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenantLinks      TenantPbxLink[]
  cdrCursors       PbxCdrCursor[]
  pbxJobs          PbxJob[]
  webhookRegistration PbxWebhookRegistration?
}



model PbxWebhookRegistration {
  id            String      @id @default(cuid())
  pbxInstanceId String      @unique
  webhookId     String
  callbackUrl   String
  status        String      @default("REGISTERED")
  lastEventAt   DateTime?
  lastError     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  pbxInstance   PbxInstance @relation(fields: [pbxInstanceId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model TenantPbxLink {
  id            String        @id @default(cuid())
  tenantId      String        @unique
  pbxInstanceId String
  pbxTenantId   String?
  pbxDomain     String?
  status        PbxLinkStatus @default(LINKED)
  lastSyncAt    DateTime?
  lastError     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pbxInstance   PbxInstance   @relation(fields: [pbxInstanceId], references: [id], onDelete: Cascade)
}

model PbxExtensionLink {
  id                  String    @id @default(cuid())
  tenantId            String
  extensionId         String    @unique
  pbxExtensionId      String
  pbxSipUsername      String
  sipPasswordHash     String?
  sipPasswordIssuedAt DateTime?
  pbxDeviceId         String?
  isSuspended         Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  extension           Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, extensionId])
  @@index([pbxExtensionId])
}

model PbxDidLink {
  id            String       @id @default(cuid())
  tenantId      String
  phoneNumberId String
  pbxDidId      String
  routeType     PbxRouteType
  routeTarget   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber   PhoneNumber  @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, phoneNumberId])
  @@index([tenantId, pbxDidId])
}

model PbxCdrCursor {
  id                String      @id @default(cuid())
  tenantId          String      @unique
  pbxInstanceId     String
  lastSeenCdrId     String?
  lastSeenTimestamp DateTime?
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pbxInstance       PbxInstance @relation(fields: [pbxInstanceId], references: [id], onDelete: Cascade)
}

model CallRecord {
  id          String   @id @default(cuid())
  tenantId    String
  direction   String
  fromNumber  String
  toNumber    String
  startedAt   DateTime
  durationSec Int      @default(0)
  disposition String?
  pbxCallId   String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pbxCallId])
  @@index([tenantId, startedAt])
}

model PbxJob {
  id            String       @id @default(cuid())
  tenantId      String
  pbxInstanceId String?
  type          String
  payload       Json
  status        PbxJobStatus @default(QUEUED)
  attempts      Int          @default(0)
  nextRunAt     DateTime     @default(now())
  lastError     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pbxInstance   PbxInstance? @relation(fields: [pbxInstanceId], references: [id], onDelete: SetNull)

  @@index([status, nextRunAt])
  @@index([tenantId, createdAt])
}


model MobileDevice {
  id            String         @id @default(cuid())
  tenantId      String
  userId        String
  platform      MobilePlatform
  expoPushToken String         @unique
  voipPushToken String?
  deviceName    String?
  lastSeenAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  acceptedInvites    CallInvite[]        @relation("CallInviteAcceptedByDevice")
  voiceClientSessions VoiceClientSession[]

  @@index([tenantId, userId])
  @@index([tenantId, platform])
}




model MobileProvisioningToken {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([expiresAt, usedAt])
}

model TurnConfig {
  id                  String          @id @default(cuid())
  scope               TurnConfigScope
  tenantId            String?         @unique
  urls                Json
  username            String?
  credentialEncrypted String?
  credentialKeyId     String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  tenant              Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([scope, updatedAt])
}

model TurnValidationJob {
  id                String                  @id @default(cuid())
  tenantId          String
  requestedByUserId String
  status            TurnValidationJobStatus @default(QUEUED)
  tokenId           String                  @unique
  expiresAt         DateTime
  requestedAt       DateTime                @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  platform          String?
  hasRelay          Boolean?
  durationMs        Int?
  errorCode         String?
  tenant            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUser   User                    @relation("TurnValidationRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, requestedAt])
  @@index([status, expiresAt])
}

model MediaTestRun {
  id              String             @id @default(cuid())
  tenantId        String
  userId          String
  tokenId         String             @unique
  expiresAt       DateTime
  createdAt       DateTime           @default(now())
  completedAt     DateTime?
  status          MediaTestRunStatus @default(QUEUED)
  platform        VoiceClientPlatform
  details         Json?
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedByUser User               @relation("MediaTestRequestedBy", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, platform])
}

model VoiceClientSession {
  id            String             @id @default(cuid())
  tenantId      String
  userId        String
  platform      VoiceClientPlatform
  deviceId      String?
  appVersion    String?
  startedAt     DateTime           @default(now())
  endedAt       DateTime?
  lastSeenAt    DateTime           @default(now())
  sipWsUrl      String?
  sipDomain     String?
  iceHasTurn    Boolean            @default(false)
  lastRegState  VoiceDiagRegState  @default(IDLE)
  lastCallState VoiceDiagCallState @default(IDLE)
  lastErrorCode String?
  lastErrorAt   DateTime?
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  device        MobileDevice?      @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  events        VoiceDiagEvent[]

  @@index([tenantId, startedAt])
  @@index([userId, lastSeenAt])
  @@index([deviceId])
}

model VoiceDiagEvent {
  id        String            @id @default(cuid())
  tenantId  String
  userId    String
  sessionId String
  createdAt DateTime          @default(now())
  type      VoiceDiagEventType
  payload   Json
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   VoiceClientSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([sessionId, createdAt])
}

model CallInvite {
  id          String           @id @default(cuid())
  tenantId    String
  userId      String
  extensionId        String?
  pbxCallId          String?
  pbxSipUsername     String?
  sipCallTarget      String?
  fromDisplay        String?
  createdByEventId   String?
  fromNumber         String
  toExtension        String
  status             CallInviteStatus @default(PENDING)
  createdAt          DateTime         @default(now())
  expiresAt          DateTime
  acceptedAt         DateTime?
  declinedAt         DateTime?
  canceledAt         DateTime?
  acceptedByDeviceId String?
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  extension          Extension?       @relation(fields: [extensionId], references: [id], onDelete: SetNull)
  acceptedByDevice   MobileDevice?    @relation("CallInviteAcceptedByDevice", fields: [acceptedByDeviceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, pbxCallId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, expiresAt])
  @@index([acceptedByDeviceId])
  @@index([userId, status, expiresAt])
}
