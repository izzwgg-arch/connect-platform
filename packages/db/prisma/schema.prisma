model TenantBillingSettings {
  id                              String         @id @default(cuid())
  tenantId                        String         @unique
  billingPlanId                   String?
  extensionPriceCents             Int            @default(3000)
  additionalPhoneNumberPriceCents Int            @default(1000)
  smsPriceCents                   Int            @default(1000)
  firstPhoneNumberFree            Boolean        @default(true)
  smsBillingEnabled               Boolean        @default(false)
  taxEnabled                      Boolean        @default(false)
  taxProfileId                    String?
  autoBillingEnabled              Boolean        @default(false)
  billingDayOfMonth               Int            @default(1)
  paymentTermsDays                Int            @default(15)
  defaultPaymentMethodId          String?
  billingEmail                    String?
  billingAddress                  Json?
  serviceAddress                  Json?
  creditsCents                    Int            @default(0)
  discountPercent                 Decimal        @default(0) @db.Decimal(7, 6)
  metadata                        Json?
  /// Display name on invoices/emails (falls back to tenant name).
  invoiceCompanyName              String?
  /// HTTPS URL for logo in HTML emails only (PDF uses text header — no remote image fetch).
  invoiceLogoUrl                  String?
  invoiceSupportEmail             String?
  invoiceSupportPhone             String?
  /// Plain text, length-capped in API (invoice PDF + email footers).
  invoiceFooterNote               String?
  invoicePaymentInstructions      String?
  /// Scheduled plan change: new plan to apply at the start of the next billing period.
  nextBillingPlanId               String?
  /// UTC midnight on the first day of the billing period when nextBillingPlanId becomes effective.
  nextBillingPlanEffectiveAt      DateTime?
  createdAt                       DateTime       @default(now())
  updatedAt                       DateTime       @updatedAt
  tenant                          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billingPlan                     BillingPlan?   @relation("CurrentBillingPlan", fields: [billingPlanId], references: [id], onDelete: SetNull)
  nextBillingPlan                 BillingPlan?   @relation("NextBillingPlan", fields: [nextBillingPlanId], references: [id], onDelete: SetNull)
  taxProfile                      TaxProfile?    @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)
  defaultPaymentMethod            PaymentMethod? @relation("DefaultTenantBillingPaymentMethod", fields: [defaultPaymentMethodId], references: [id], onDelete: SetNull)

  @@index([taxProfileId])
  @@index([autoBillingEnabled, billingDayOfMonth])
  @@index([nextBillingPlanId])
}

