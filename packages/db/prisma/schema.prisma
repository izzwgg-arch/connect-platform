// Connect-owned CDR — one row per completed canonical call.
// Populated by the telephony service via /internal/cdr-ingest when a call ends.
// This is the authoritative source for dashboard KPI cards and call history.
model ConnectCdr {
  id                     String    @id @default(cuid())
  linkedId               String    @unique // Asterisk Linkedid — canonical dedupe key
  tenantId               String? // Connect Tenant.id when linked; else vpbx:{slug}; null = unassigned
  pbxVitalTenantId       String? // VitalPBX tenant_id (numeric string, e.g. "8")
  pbxTenantCode          String? // Canonical label e.g. "T8"
  tenantResolutionSource String? // audit: how tenantId was chosen
  fromNumber             String?
  fromName               String? // CNAM from AMI CallerIDName (caller's display name)
  toNumber               String?
  direction              String // "incoming" | "outgoing" | "internal" | "unknown"
  disposition            String // "answered" | "missed" | "busy" | "failed" | "canceled" | "unknown"
  startedAt              DateTime
  answeredAt             DateTime?
  endedAt                DateTime
  durationSec            Int       @default(0) // wall time: endedAt - startedAt (seconds)
  talkSec                Int       @default(0) // talk time: endedAt - answeredAt (0 if unanswered)
  queueId                String?
  hangupCause            String?
  dcontext               String? // AMI Cdr dcontext — most authoritative direction signal (e.g. "ext-local-gesheft")
  dcontextsSeen          Json? // string[] — all AMI Cdr dcontext values observed for this linkedId
  channelsSeen           Json? // string[] — accumulated channel names for direction evidence
  rawLegCount            Int       @default(1) // how many CDR notifications were received for this linkedId (channel-leg count)
  isForwarded            Boolean   @default(false) // true for :out rows — inbound call automatically forwarded to an external number (find-me/follow-me)
  recordingPath          String? // deterministic path "YYYY/MM/DD/<linkedId>.wav" computed at ingest; null when call is not recorded
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([tenantId, startedAt]) // per-tenant KPI queries
  @@index([startedAt]) // global aggregate queries
  @@index([tenantId, direction, startedAt]) // typed per-tenant KPI queries
}

model Voicemail {
  id             String    @id @default(cuid())
  tenantId       String? // Connect Tenant.id; null = unresolved
  pbxMessageId   String    @unique // stable dedup key: "{pbxTenantId}|{ext}|{origtime}|{callerDigits10}"
  extension      String // mailbox extension number (e.g. "104")
  pbxExtensionId String? // VitalPBX resource ID for this extension
  callerNumber   String?
  callerName     String?
  durationSec    Int       @default(0)
  folder         String    @default("inbox") // normalised: "inbox" | "old" | "urgent"
  pbxFolder      String? // raw PBX folder (e.g. "INBOX", "Old", "Urgent")
  pbxMsgNum      String? // PBX message file basename (e.g. "msg0007")
  pbxRecfile     String? // VitalPBX-relative playback path (e.g. "/static/<tok>/voicemail/<tenant>/<ext>/INBOX/msg0007.wav") — token-authenticated, no app-key needed
  listened       Boolean   @default(false)
  receivedAt     DateTime
  readAt         DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

