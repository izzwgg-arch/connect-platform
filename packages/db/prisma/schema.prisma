  firstName                      String?
  lastName                       String?
  displayName                    String?
  avatarUrl                      String?
  avatarStorageKey               String?
  phone                          String?
  title                          String?
  department                     String?
  notes                          String?
  passwordHash                   String
  role                           UserRole                          @default(USER)
  status                         UserStatus                        @default(ACTIVE)
  emailVerifiedAt                DateTime?
  lastLoginAt                    DateTime?
  forcePasswordReset             Boolean                           @default(false)
  updatedAt                      DateTime                          @updatedAt
  createdAt                      DateTime                          @default(now())
  tenant                         Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents                    AuditLog[]                        @relation("AuditActor")
  passwordTokens                 UserPasswordToken[]               @relation("UserPasswordTokens")
  createdPasswordTokens          UserPasswordToken[]               @relation("UserPasswordTokenCreator")
  createdProviderCredentials     ProviderCredential[]              @relation("ProviderCredentialCreatedBy")
  updatedProviderCredentials     ProviderCredential[]              @relation("ProviderCredentialUpdatedBy")
