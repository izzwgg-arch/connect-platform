generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenDlcStatus {
  DRAFT
  SUBMITTED
  NEEDS_INFO
  APPROVED
  REJECTED
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
  PAUSED
  NEEDS_APPROVAL
}

enum SmsMessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
}

enum IntegrationProvider {
  TWILIO
  VOIPMS
}

enum SmsSendMode {
  TEST
  LIVE
}

enum SmsProviderRoutingMode {
  SINGLE_PRIMARY
  FAILOVER
}

enum PhoneNumberProvider {
  TWILIO
  VOIPMS
}

enum PhoneNumberStatus {
  ACTIVE
  RELEASING
  RELEASED
  SUSPENDED
}

enum SubscriptionStatus {
  NONE
  PENDING
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model Tenant {
  id                            String                 @id @default(cuid())
  name                          String
  isApproved                    Boolean                @default(false)
  dailySmsCap                   Int                    @default(100)
  perSecondRate                 Float                  @default(1.0)
  firstCampaignRequiresApproval Boolean                @default(true)
  smsSendMode                   SmsSendMode            @default(TEST)
  smsLiveEnabledAt              DateTime?
  smsLiveEnabledByUserId        String?
  dailySmsLimit                 Int                    @default(500)
  hourlySmsLimit                Int                    @default(100)
  perSecondRateLimit            Int                    @default(5)
  maxCampaignSize               Int                    @default(2000)
  smsSuspended                  Boolean                @default(false)
  smsSuspendedReason            String?
  smsSuspendedAt                DateTime?
  smsRoutingMode                SmsProviderRoutingMode @default(FAILOVER)
  smsPrimaryProvider            IntegrationProvider    @default(TWILIO)
  smsSecondaryProvider          IntegrationProvider?   @default(VOIPMS)
  smsProviderLock               IntegrationProvider?
  smsProviderLockReason         String?
  smsProviderLockedAt           DateTime?
  smsProviderLockedByUserId     String?
  defaultSmsFromNumberId        String?
  defaultVoiceFromNumberId      String?
  numberPurchaseEnabled         Boolean                @default(true)
  smsSubscriptionRequired       Boolean                @default(true)
  smsBillingEnforced            Boolean                @default(true)
  createdAt                     DateTime               @default(now())
  users                         User[]
  tenDlcSubs                    TenDlcSubmission[]
  campaigns                     SmsCampaign[]
  numbers                       PhoneNumber[]          @relation("TenantOwnedNumbers")
  audits                        AuditLog[]
  providerCredentials           ProviderCredential[]
  webhookEvents                 SmsWebhookEvent[]
  providerHealth                ProviderHealth[]
  subscription                  Subscription?
  paymentEvents                 PaymentEvent[]
  usageLedger                   UsageLedger[]
  receipts                      Receipt[]
  alerts                        Alert[]
  smsLiveEnabledByUser          User?                  @relation("TenantSmsLiveEnabledBy", fields: [smsLiveEnabledByUserId], references: [id], onDelete: SetNull)
  smsProviderLockedByUser       User?                  @relation("TenantSmsProviderLockedBy", fields: [smsProviderLockedByUserId], references: [id], onDelete: SetNull)
  defaultSmsFromNumber          PhoneNumber?           @relation("TenantDefaultSmsFromNumber", fields: [defaultSmsFromNumberId], references: [id], onDelete: SetNull)
}

model User {
  id                         String               @id @default(cuid())
  tenantId                   String
  email                      String               @unique
  passwordHash               String
  role                       String               @default("USER")
  createdAt                  DateTime             @default(now())
  tenant                     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditEvents                AuditLog[]           @relation("AuditActor")
  createdProviderCredentials ProviderCredential[] @relation("ProviderCredentialCreatedBy")
  updatedProviderCredentials ProviderCredential[] @relation("ProviderCredentialUpdatedBy")
  smsLiveEnabledTenants      Tenant[]             @relation("TenantSmsLiveEnabledBy")
  smsProviderLockedTenants   Tenant[]             @relation("TenantSmsProviderLockedBy")
}

model Subscription {
  id                      String             @id @default(cuid())
  tenantId                String             @unique
  planCode                String
  priceCents              Int
  currency                String             @default("USD")
  status                  SubscriptionStatus @default(NONE)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  provider                String             @default("SOLA_CARDKNOX")
  providerCustomerId      String?
  providerSubscriptionId  String?
  providerPaymentMethodId String?
  billingEmail           String?
  paymentMethodBrand      String?
  paymentMethodLast4      String?
  paymentMethodExpMonth   String?
  paymentMethodExpYear    String?
  lastPaymentStatus       PaymentStatus?
  lastPaymentAt           DateTime?
  lastFailureReason       String?
  pastDueSince            DateTime?
  retryCount              Int                @default(0)
  nextRetryAt             DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  paymentEvents           PaymentEvent[]
  receipts                Receipt[]
}

model PaymentEvent {
  id              String       @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  provider        String
  providerEventId String?
  type            String
  status          PaymentStatus
  amountCents     Int?
  currency        String?
  payload         Json
  receivedAt      DateTime     @default(now())
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, receivedAt])
  @@unique([provider, providerEventId])
}

model UsageLedger {
  id            String   @id @default(cuid())
  tenantId      String
  type          String
  quantity      Int      @default(1)
  unitPriceCents Int
  totalCents    Int
  referenceId   String?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, occurredAt])
}

model TenDlcSubmission {
  id                    String       @id @default(cuid())
  tenantId              String
  legalName             String
  dba                   String?
  einEncrypted          String
  businessType          String
  websiteUrl            String
  addressStreet         String
  addressCity           String
  addressState          String
  addressPostalCode     String
  addressCountry        String
  supportEmail          String
  supportPhone          String
  useCaseCategory       String
  sampleMessage1        String
  sampleMessage2        String
  sampleMessage3        String
  optInMethod           String
  optInWorkflow         String
  optInProofUrl         String?
  messagesPerDay        Int
  messagesPerMonth      Int
  includesEmbeddedLinks Boolean
  includesPhoneNumbers  Boolean
  includesAffiliateMktg Boolean
  ageGatedContent       Boolean
  termsAccepted         Boolean
  signatureName         String
  signatureDate         DateTime
  status                TenDlcStatus @default(SUBMITTED)
  internalNotes         String?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  createdAt             DateTime     @default(now())
  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model SmsCampaign {
  id               String         @id @default(cuid())
  tenantId         String
  name             String
  message          String
  fromNumber       String
  audienceType     String
  requiresApproval Boolean        @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  holdReason       String?
  riskScore        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  createdAt        DateTime       @default(now())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages         SmsMessage[]
}

model SmsMessage {
  id                   String               @id @default(cuid())
  campaignId           String
  toNumber             String
  fromNumber           String
  fromNumberId         String?
  body                 String
  status               SmsMessageStatus     @default(QUEUED)
  providerMessageId    String?
  providerStatus       String?
  provider             IntegrationProvider?
  providerErrorCode    String?
  providerAttemptedAt  DateTime?
  providerRoute        String?
  lastProviderUpdateAt DateTime?
  deliveryUpdatedAt    DateTime?
  error                String?
  createdAt            DateTime             @default(now())
  sentAt               DateTime?
  campaign             SmsCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fromNumberRef        PhoneNumber?         @relation("SmsMessageFromNumber", fields: [fromNumberId], references: [id], onDelete: SetNull)
  webhookEvents        SmsWebhookEvent[]
}

model SmsWebhookEvent {
  id                String              @id @default(cuid())
  tenantId          String?
  provider          IntegrationProvider
  messageId         String?
  providerMessageId String
  eventType         String
  payload           Json
  receivedAt        DateTime            @default(now())
  tenant            Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  message           SmsMessage?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([provider, providerMessageId])
  @@index([tenantId, receivedAt])
}

model ProviderHealth {
  id               String              @id @default(cuid())
  tenantId         String
  provider         IntegrationProvider
  windowStart      DateTime
  sentCount        Int                 @default(0)
  failCount        Int                 @default(0)
  lastErrorCode    String?
  lastErrorAt      DateTime?
  circuitOpenUntil DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, windowStart])
  @@index([tenantId, provider])
}

model PhoneNumber {
  id                String              @id @default(cuid())
  tenantId          String
  provider          PhoneNumberProvider
  phoneNumber       String              @unique
  providerId        String?
  friendlyName      String?
  capabilities      Json?
  region            String?
  areaCode          String?
  monthlyCostCents  Int?
  status            PhoneNumberStatus   @default(ACTIVE)
  purchasedAt       DateTime            @default(now())
  releasedAt        DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  tenant            Tenant              @relation("TenantOwnedNumbers", fields: [tenantId], references: [id], onDelete: Cascade)
  defaultForTenants Tenant[]            @relation("TenantDefaultSmsFromNumber")
  smsMessages       SmsMessage[]        @relation("SmsMessageFromNumber")

  @@index([tenantId, status])
  @@index([provider, status])
}

model ProviderCredential {
  id                   String              @id @default(cuid())
  tenantId             String
  provider             IntegrationProvider
  label                String?
  isEnabled            Boolean             @default(false)
  credentialsEncrypted String
  credentialsKeyId     String              @default("v1")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdByUserId      String
  updatedByUserId      String
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser        User                @relation("ProviderCredentialCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser        User                @relation("ProviderCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, provider])
}

model AuditLog {
  id          String               @id @default(cuid())
  tenantId    String
  action      String
  entityType  String
  entityId    String
  actorUserId String?
  provider    IntegrationProvider?
  createdAt   DateTime             @default(now())
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUser   User?                @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
}


model Receipt {
  id             String       @id @default(cuid())
  tenantId       String
  subscriptionId String
  amountCents    Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model Alert {
  id          String   @id @default(cuid())
  tenantId    String
  severity    String
  category    String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())
  acknowledgedAt DateTime?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
}
