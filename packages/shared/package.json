{
  "name": "@connect/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./queues": {
      "types": "./src/queues.ts",
      "default": "./src/queues.ts"
    },
    "./src/queues": {
      "types": "./src/queues.ts",
      "default": "./src/queues.ts"
    },
    "./chatSignedUrl": {
      "types": "./src/chatSignedUrl.ts",
      "default": "./src/chatSignedUrl.ts"
    },
    "./chatAttachmentStorage": {
      "types": "./src/chatAttachmentStorage.ts",
      "default": "./src/chatAttachmentStorage.ts"
    },
    "./voipMsInboundMms": {
      "types": "./src/voipMsInboundMms.ts",
      "default": "./src/voipMsInboundMms.ts"
    },
    "./mohRuntimeClass": {
      "types": "./src/mohRuntimeClass.ts",
      "default": "./src/mohRuntimeClass.ts"
    },
    "./ariBridgedSnapshot": {
      "types": "./src/ariBridgedSnapshot.ts",
      "default": "./src/ariBridgedSnapshot.ts"
    },
    "./crmEmailTemplates": {
      "types": "./src/crmEmailTemplates.ts",
      "default": "./src/crmEmailTemplates.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/voicemailSyncFair.test.ts src/voicemailIngest.test.ts src/ariBridgedSnapshot.test.ts src/expoMobilePushFormat.test.ts src/portalPermissions.crm.test.ts src/portalPermissions.customRoles.test.ts src/crmEmailTemplates.test.ts src/smsInbox.test.ts",
    "lint": "echo lint-shared"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.20.5"
  }
}
