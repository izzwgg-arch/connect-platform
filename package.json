{
  "name": "connect-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier -w .",
    "db:generate": "pnpm --filter @connect/db prisma:generate",
    "db:migrate": "pnpm --filter @connect/db prisma:migrate",
    "smoke:pbx:v1.1.0": "node scripts/smoke-v1.1.0.mjs",
    "smoke:pbx": "node scripts/smoke-v1.1.0.mjs",
    "audit-pbx": "node scripts/pbx-live-observe.mjs",
    "mobile:start": "pnpm --filter @connect/mobile start",
    "mobile:android": "pnpm --filter @connect/mobile android",
    "mobile:ios": "pnpm --filter @connect/mobile ios",
    "build:changed": "bash scripts/build-changed.sh",
    "smoke:fast": "bash scripts/smoke-fast.sh"
  },
  "devDependencies": {
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "overrides": {
      "react-native-gesture-handler": "~2.16.1",
      "react-native-safe-area-context": "4.10.5",
      "react-native-screens": "3.31.1"
    }
  }
}
