NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# Optional: WebSocket URL for the telephony real-time service (AMI event stream).
# When set, the portal connects for live call/extension/queue state updates.
# Must use wss:// in production (nginx proxies external wss: → internal ws:).
# Example (production):  wss://app.connectcomunications.com/ws/telephony
# Example (dev):         ws://localhost:3003/ws/telephony
# Leave blank to fall back to existing API polling mode.
NEXT_PUBLIC_TELEPHONY_WS_URL=
