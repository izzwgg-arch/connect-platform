{
  "name": "@connect/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "pbx:diagnose": "tsx scripts/run-pbx-diagnostics.ts",
    "pbx:enable-instances": "tsx scripts/enable-pbx-instances.ts",
    "pbx:diagnose-by-name": "tsx scripts/pbx-diagnose-by-tenant-name.ts",
    "pbx:link-tenant": "tsx scripts/link-tenant-to-pbx.ts",
    "pbx:link-all-tenants": "tsx scripts/link-all-tenants-to-pbx.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo lint-api",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@connect/db": "workspace:*",
    "@connect/integrations": "workspace:*",
    "@connect/shared": "workspace:*",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.0",
    "fastify": "^5.6.0",
    "ioredis": "^5.8.0",
    "zod": "^3.24.1",
    "@connect/security": "workspace:*"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
