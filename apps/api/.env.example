PORT=3001

# ── Telephony service (apps/telephony) ────────────────────────────────────────
# AMI credentials — must match the AMI manager.conf entry on the PBX
# Confirmed username on this PBX: connectcommsgefenu (not "...w")
AMI_USERNAME=connectcommsgefenu
AMI_PASSWORD=

# ARI credentials — must match the ARI ari.conf entry on the PBX
ARI_BASE_URL=http://209.145.60.79:8088
ARI_USERNAME=connectcomms
ARI_PASSWORD=
ARI_APP_NAME=connectcomms
# Same Asterisk ARI user/password as above — used for /ari/bridges + /ari/channels (active calls).
PBX_ARI_USER=
PBX_ARI_PASS=
# When true, logs full bridged-active verification JSON on each pbx live ARI fetch (noisy).
PBX_ARI_BRIDGED_VERIFY_LOG=false
DATABASE_URL=postgresql://connectcomms:CHANGE_ME@127.0.0.1:5432/connectcomms
JWT_SECRET=CHANGE_ME
# TEMPORARY: enables POST /admin/dev/generate-observe-token outside NODE_ENV=development (min 16 chars).
# Send the same value as header X-Dev-Observe-Secret or JSON body "secret". Remove with the endpoint.
DEV_OBSERVE_TOKEN_SECRET=
CREDENTIALS_MASTER_KEY=CHANGE_ME_64_HEX
SMS_PROVIDER_TEST_MODE=true
SOLA_CARDKNOX_API_BASE_URL=
SOLA_CARDKNOX_API_KEY=
SOLA_CARDKNOX_API_SECRET=
SOLA_CARDKNOX_WEBHOOK_SECRET=
SOLA_CARDKNOX_MODE=sandbox
SOLA_CARDKNOX_SIMULATE=false
SOLA_CARDKNOX_HOSTED_SESSION_PATH=/hosted-checkout/sessions
SOLA_CARDKNOX_CHARGE_PATH=/subscriptions/charge
SOLA_CARDKNOX_CANCEL_PATH=/subscriptions/cancel
SOLA_CARDKNOX_WEBHOOK_SIGNATURE_HEADER=x-sola-signature
SOLA_CARDKNOX_WEBHOOK_TIMESTAMP_HEADER=x-sola-timestamp
BILLING_RECEIPT_EMAIL_ENDPOINT=
PBX_SIMULATE=false
PBX_BASE_URL=
PBX_API_TOKEN=
PBX_API_SECRET=
PBX_TIMEOUT_MS=10000
# When true, ?source=pbx on GET /dashboard/call-kpis uses VitalPBX /api/v2/cdr per tenant (very heavy).
# Leave false in production — default KPIs use ConnectCdr only.
CALL_KPIS_USE_VITALPBX_API=false
# IANA timezone for "today" KPI (e.g. America/New_York). If unset, UTC midnight is used.
PBX_TIMEZONE=
# Comma-separated VitalPBX tenant names to skip when fanning out cdr.list (diagnostics / source=pbx KPI). Default: smoke,billing,test. Empty or "none" includes every tenant (do not exclude production slugs like vitalpbx unless intentional).
VITALPBX_CDR_AGGREGATE_EXCLUDE_NAMES=
# Set to 1 to log one structured line per successful POST /internal/cdr-ingest persist (targeted pipeline diag; remove after use).
CDR_PIPELINE_DIAG=
# ── WebRTC / SIP provisioning ─────────────────────────────────────────────────
# PBX WebSocket endpoint for browser/mobile SIP softphone.
# Confirmed working on this PBX: WSS transport on port 8089, path /ws.
# REQUIRED for browser/mobile phone registration to work.
PBX_WS_ENDPOINT=wss://209.145.60.79:8089/ws

# STUN server for WebRTC ICE (used when tenant has no custom ICE servers configured).
# Public Google STUN is used as default; replace with a local/private STUN if preferred.
STUN_SERVER=stun:stun.l.google.com:19302

# TURN server for WebRTC ICE — REQUIRED for audio behind strict NAT.
# Leave blank to skip TURN (STUN-only; audio will fail for external users behind symmetric NAT).
# Format: hostname or IP only (port 3478 is assumed). Or prefix with turn: to specify port.
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# Internal URL for the telephony service (used by /voice/webrtc/health to fetch AMI/ARI state).
# Default: http://localhost:3003
TELEPHONY_INTERNAL_URL=http://localhost:3003
PBX_MASTER_KEY=CHANGE_ME_64_HEX
VOICE_SIMULATE=false
MOBILE_PUSH_SIMULATE=false
EXPO_PUSH_ACCESS_TOKEN=
PBX_WEBHOOK_TOKEN=
PBX_WEBHOOK_SIGNATURE_SECRET=
PBX_WEBHOOK_ALLOWED_IPS=
PBX_WEBHOOK_VERIFY_MODE=token
# Optional canonical callback URL for PBX webhook registration.
# Defaults to NEXT_PUBLIC_API_URL/webhooks/pbx when NEXT_PUBLIC_API_URL is set,
# otherwise https://app.connectcomunications.com/api/webhooks/pbx.
PBX_WEBHOOK_CALLBACK_URL=
PBX_WEBHOOK_REGISTER_PATH=
PBX_WEBHOOK_LIST_PATH=
PBX_WEBHOOK_DELETE_PATH=
PBX_ACTIVE_CALLS_PATH=
PBX_SUPPORTS_WEBHOOKS=
PBX_SUPPORTS_ACTIVE_CALL_POLLING=
PBX_WEBHOOK_EVENT_TYPES=call.ringing,call.answered,call.hangup

# Optional secret used to sign TURN validation tokens (falls back to JWT_SECRET).
TURN_VALIDATION_TOKEN_SECRET=

# Optional secret used to sign mobile provisioning tokens (falls back to JWT_SECRET).
MOBILE_PROVISIONING_TOKEN_SECRET=

# SBC status probe settings
SBC_KAMAILIO_HOST=sbc-kamailio
SBC_KAMAILIO_SIP_PORT=5060
SBC_KAMAILIO_TCP_PORT=5061
SBC_RTPENGINE_HOST=sbc-rtpengine
SBC_RTPENGINE_CTRL_PORT=2223
SBC_PBX_HOST=pbx
SBC_PBX_PORT=5060
SBC_KAMAILIO_CONTAINER=sbc-kamailio
SBC_RTPENGINE_CONTAINER=sbc-rtpengine

# ── CRM Google OAuth (CRM Email + CRM Drive) ──────────────────────────────────
# Shared Google OAuth 2.0 credentials used by both CRM Email (Gmail send/reply)
# and CRM Drive (Google Drive folder connection + document matching).
# A single Google Cloud Console OAuth app covers both scopes — no separate app needed.
# Required for CRM email send, reply tracking, and Drive integration.
# Redirect URI must be registered in Google Cloud Console under Authorized redirect URIs.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# For local development: http://localhost:3001/crm/drive/oauth/callback
# For production: https://app.connectcomunications.com/api/crm/drive/oauth/callback
GOOGLE_OAUTH_REDIRECT_URI=

# ── CRM Lead Document Storage (Phase 3) ───────────────────────────────────────
# Root directory for imported tenant lead documents (Drive files pulled to local storage).
# Default: <cwd>/data/crm-lead-docs (ephemeral — use a persistent volume in production).
# In production, point to a persistent path, e.g. /opt/connectcomms/crm-docs
CRM_DOC_STORAGE_DIR=
# Maximum file size allowed for document import (bytes). Default: 50 MB (52428800).
CRM_DOC_IMPORT_MAX_BYTES=
# HMAC secret for signed document-open URLs. Falls back to PROMPT_URL_SIGNING_SECRET,
# MOH_URL_SIGNING_SECRET, CDR_INGEST_SECRET, and finally a hardcoded dev fallback.
# Set explicitly in production if those shared secrets are not present.
CRM_DOC_URL_SIGNING_SECRET=

# ── AI Lead Intelligence (Phase 7) ────────────────────────────────────────────
# Required for CRM lead intelligence reports. If unset, intelligence generation
# returns a clear 'ai_not_configured' error; the rest of the CRM is unaffected.
OPENAI_API_KEY=
# Optional: override the OpenAI model (default: gpt-4o-mini)
LEAD_INTELLIGENCE_MODEL=

# ── CRM Document OCR (Phase 5B) ───────────────────────────────────────────────
# Enable OCR text extraction for image files (PNG, JPG, JPEG, TIFF).
# Disabled by default. Requires Tesseract.js language data (downloaded from CDN
# on first use, or pre-loaded via CRM_OCR_LANG_PATH for air-gapped environments).
CRM_OCR_ENABLED=false
# Maximum file size to submit to OCR (bytes). Default: 10 MB.
CRM_OCR_MAX_FILE_BYTES=10485760
# OCR provider. Only "tesseract_js" is supported currently.
CRM_OCR_PROVIDER=tesseract_js
# Tesseract language code. Default: eng (English).
CRM_OCR_LANG=eng
# Optional: path to pre-downloaded Tesseract .traineddata files.
# Required for air-gapped / Docker environments without internet access.
# Example: /opt/tessdata/
CRM_OCR_LANG_PATH=

# ── CRM Batch Pipeline (Phase 8) ──────────────────────────────────────────────

# Minutes before a RUNNING pipeline run is considered stale (server crash recovery).
# A stale run is automatically marked FAILED on the next start/continue call,
# freeing the slot for a new run. Default: 30.
CRM_PIPELINE_STALE_MINUTES=30

# Global ceiling for items processed per pipeline step per HTTP call.
# Each step also has its own conservative natural limit (5 for text extraction,
# 10 for discovery, etc.) — the effective limit is min(natural_limit, this value).
# Reduce in staging/test environments to process smaller chunks.
# Range: 1–50. Default: 20.
CRM_PIPELINE_MAX_STEP_ITEMS=20
