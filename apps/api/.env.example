PORT=3001

# ── Telephony service (apps/telephony) ────────────────────────────────────────
# AMI credentials — must match the AMI manager.conf entry on the PBX
# Confirmed username on this PBX: connectcommsgefenu (not "...w")
AMI_USERNAME=connectcommsgefenu
AMI_PASSWORD=

# ARI credentials — must match the ARI ari.conf entry on the PBX
ARI_BASE_URL=http://209.145.60.79:8088
ARI_USERNAME=connectcomms
ARI_PASSWORD=
ARI_APP_NAME=connectcomms
DATABASE_URL=postgresql://connectcomms:CHANGE_ME@127.0.0.1:5432/connectcomms
JWT_SECRET=CHANGE_ME
CREDENTIALS_MASTER_KEY=CHANGE_ME_64_HEX
SMS_PROVIDER_TEST_MODE=true
SOLA_CARDKNOX_API_BASE_URL=
SOLA_CARDKNOX_API_KEY=
SOLA_CARDKNOX_API_SECRET=
SOLA_CARDKNOX_WEBHOOK_SECRET=
SOLA_CARDKNOX_MODE=sandbox
SOLA_CARDKNOX_SIMULATE=false
SOLA_CARDKNOX_HOSTED_SESSION_PATH=/hosted-checkout/sessions
SOLA_CARDKNOX_CHARGE_PATH=/subscriptions/charge
SOLA_CARDKNOX_CANCEL_PATH=/subscriptions/cancel
SOLA_CARDKNOX_WEBHOOK_SIGNATURE_HEADER=x-sola-signature
SOLA_CARDKNOX_WEBHOOK_TIMESTAMP_HEADER=x-sola-timestamp
BILLING_RECEIPT_EMAIL_ENDPOINT=
PBX_SIMULATE=false
PBX_BASE_URL=
PBX_API_TOKEN=
PBX_API_SECRET=
PBX_TIMEOUT_MS=10000
# IANA timezone for "today" KPI (e.g. America/New_York). If unset, UTC midnight is used.
PBX_TIMEZONE=
# ── WebRTC / SIP provisioning ─────────────────────────────────────────────────
# PBX WebSocket endpoint for browser/mobile SIP softphone.
# Confirmed working on this PBX: WSS transport on port 8089, path /ws.
# REQUIRED for browser/mobile phone registration to work.
PBX_WS_ENDPOINT=wss://209.145.60.79:8089/ws

# STUN server for WebRTC ICE (used when tenant has no custom ICE servers configured).
# Public Google STUN is used as default; replace with a local/private STUN if preferred.
STUN_SERVER=stun:stun.l.google.com:19302

# TURN server for WebRTC ICE — REQUIRED for audio behind strict NAT.
# Leave blank to skip TURN (STUN-only; audio will fail for external users behind symmetric NAT).
# Format: hostname or IP only (port 3478 is assumed). Or prefix with turn: to specify port.
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# Internal URL for the telephony service (used by /voice/webrtc/health to fetch AMI/ARI state).
# Default: http://localhost:3003
TELEPHONY_INTERNAL_URL=http://localhost:3003
PBX_MASTER_KEY=CHANGE_ME_64_HEX
VOICE_SIMULATE=false
MOBILE_PUSH_SIMULATE=false
EXPO_PUSH_ACCESS_TOKEN=
PBX_WEBHOOK_TOKEN=
PBX_WEBHOOK_SIGNATURE_SECRET=
PBX_WEBHOOK_ALLOWED_IPS=
PBX_WEBHOOK_VERIFY_MODE=token
# Optional canonical callback URL for PBX webhook registration.
# Defaults to NEXT_PUBLIC_API_URL/webhooks/pbx when NEXT_PUBLIC_API_URL is set,
# otherwise https://app.connectcomunications.com/api/webhooks/pbx.
PBX_WEBHOOK_CALLBACK_URL=
PBX_WEBHOOK_REGISTER_PATH=
PBX_WEBHOOK_LIST_PATH=
PBX_WEBHOOK_DELETE_PATH=
PBX_ACTIVE_CALLS_PATH=
PBX_SUPPORTS_WEBHOOKS=
PBX_SUPPORTS_ACTIVE_CALL_POLLING=
PBX_WEBHOOK_EVENT_TYPES=call.ringing,call.answered,call.hangup

# Optional secret used to sign TURN validation tokens (falls back to JWT_SECRET).
TURN_VALIDATION_TOKEN_SECRET=

# Optional secret used to sign mobile provisioning tokens (falls back to JWT_SECRET).
MOBILE_PROVISIONING_TOKEN_SECRET=

# SBC status probe settings
SBC_KAMAILIO_HOST=sbc-kamailio
SBC_KAMAILIO_SIP_PORT=5060
SBC_KAMAILIO_TCP_PORT=5061
SBC_RTPENGINE_HOST=sbc-rtpengine
SBC_RTPENGINE_CTRL_PORT=2223
SBC_PBX_HOST=pbx
SBC_PBX_PORT=5060
SBC_KAMAILIO_CONTAINER=sbc-kamailio
SBC_RTPENGINE_CONTAINER=sbc-rtpengine
