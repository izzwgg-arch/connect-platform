# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# ── Authentication (shared JWT secret with the API server) ────────────────────
# WebSocket clients must present a valid JWT signed with this secret.
JWT_SECRET=CHANGE_ME

# ── PBX server (209.145.60.79) ────────────────────────────────────────────────
# Firewall rules required:
#   45.14.194.179 → 209.145.60.79:5038  (AMI TCP)
#   45.14.194.179 → 209.145.60.79:8088  (ARI REST HTTP)
# Browser/mobile SIP signaling:
#   Browser/Mobile  → 209.145.60.79:8089  (SIP/WSS — PJSIP transport-wss)
# ARI WebSocket: NOT available on this PBX build (res_ari_websockets.so absent).
#   AMI is the primary event source. ARI REST is used for call-control actions only.

PBX_HOST=209.145.60.79

# AMI — Asterisk Manager Interface (TCP port 5038)
AMI_PORT=5038
AMI_USERNAME=connectcommsgefenu
AMI_PASSWORD=CHANGE_ME

# ARI — Asterisk REST Interface (HTTP port 8088)
ARI_BASE_URL=http://209.145.60.79:8088
ARI_USERNAME=connectcomms
ARI_PASSWORD=CHANGE_ME
ARI_APP_NAME=connectcomms

# ── Telephony service tuning ──────────────────────────────────────────────────
# WebSocket path for the telephony event stream
TELEPHONY_WS_PATH=/ws/telephony

# How often to send full snapshots to connected WS clients (ms)
TELEPHONY_SNAPSHOT_INTERVAL_MS=5000

# Debounce window for rapid-fire state updates before broadcasting (ms)
TELEPHONY_EVENT_DEBOUNCE_MS=100

# Set to "true" to log every raw AMI frame (verbose — dev only)
ENABLE_TELEPHONY_DEBUG=false

# ── Connect CDR persistence ───────────────────────────────────────────────────
# When set, completed calls are POSTed to this URL so the API can persist them
# in the ConnectCdr table. Leave empty to disable CDR persistence.
# In docker-compose, this should be http://api:3001/internal/cdr-ingest
CDR_INGEST_URL=http://api:3001/internal/cdr-ingest

# Shared secret sent as x-cdr-secret header. Must match CDR_INGEST_SECRET in API.
CDR_INGEST_SECRET=CHANGE_ME
