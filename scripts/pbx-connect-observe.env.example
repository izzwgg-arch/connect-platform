# Copy to scripts/pbx-connect-observe.env (gitignored) before running pbx-connect-observe-hour.ps1
# Use a super-admin JWT for the Connect API (portal admin token), or POST
#   /admin/dev/generate-observe-token
# on the API (after deploy: path must work under /api/...; production needs DEV_OBSERVE_TOKEN_SECRET unless NODE_ENV=development).

# Production example (no trailing slash):
# CONNECT_OBSERVE_API_BASE=https://app.connectcomunications.com/api

CONNECT_OBSERVE_API_BASE=http://127.0.0.1:3001
CONNECT_OBSERVE_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional one-shot: ConnectCdr direction breakdown (same super-admin token)
# GET %CONNECT_OBSERVE_API_BASE%/admin/diagnostics/connect-cdr-today-breakdown
# VitalPBX dashboard-equivalent totals (cdr.list):
# GET %CONNECT_OBSERVE_API_BASE%/admin/diagnostics/pbx-cdr-today-kpis
